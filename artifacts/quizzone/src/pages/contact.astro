---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
---

<Layout
  title="Contact QuizZone — Get in Touch"
  description="Contact the QuizZone team with questions, suggestions, or feedback about our free online trivia quiz platform. We respond within 24–48 hours."
  canonical="/contact"
>
  <Header />

  <main style="max-width:700px;margin:0 auto;padding:16px 16px 32px;">

    <!-- Back button -->
    <a href="/" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:700;color:#92733a;margin-bottom:14px;padding:8px 14px;background:rgba(255,255,255,0.6);border-radius:100px;">
      ← Home
    </a>

    <!-- Hero -->
    <div style="background:#1a1040;border-radius:20px;padding:28px 20px;text-align:center;margin-bottom:16px;">
      <div style="font-size:44px;margin-bottom:10px;">✉️</div>
      <h1 style="font-size:24px;font-weight:900;color:white;margin-bottom:6px;">Contact Us</h1>
      <p style="font-size:13px;color:rgba(255,255,255,0.6);max-width:280px;margin:0 auto;">We'd love to hear from you. Drop us a message and we'll get back to you!</p>
    </div>

    <!-- Info cards -->
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:14px;">
      {[['✉️','Email','hello@quizzone.app'],['🐦','Twitter','@QuizZoneApp'],['⏰','Response','24–48 hours']].map(([ic,l,v]) => (
        <div style="background:white;border-radius:14px;padding:14px 10px;text-align:center;box-shadow:0 2px 8px rgba(0,0,0,0.07);">
          <div style="font-size:22px;margin-bottom:6px;">{ic}</div>
          <div style="font-size:10px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:3px;">{l}</div>
          <div style="font-size:11px;font-weight:600;color:#1a1040;line-height:1.3;">{v}</div>
        </div>
      ))}
    </div>

    <!-- Form card -->
    <div style="background:white;border-radius:20px;padding:22px 20px;box-shadow:0 2px 8px rgba(0,0,0,0.08);">
      <h2 style="font-size:17px;font-weight:800;color:#1a1040;margin-bottom:18px;">Send a message</h2>

      <form id="contact-form" novalidate style="display:flex;flex-direction:column;gap:14px;">

        <div>
          <label for="name" style="display:block;font-size:12px;font-weight:700;color:#374151;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">Your Name</label>
          <input type="text" id="name" name="name" required placeholder="John Doe"
            style="width:100%;padding:13px 16px;border:2px solid #e5e7eb;border-radius:12px;font-size:14px;color:#1a1040;font-family:inherit;outline:none;transition:border-color 0.15s;box-sizing:border-box;"
            onfocus="this.style.borderColor='#7c3aed';" onblur="this.style.borderColor='#e5e7eb';" />
        </div>

        <div>
          <label for="email" style="display:block;font-size:12px;font-weight:700;color:#374151;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">Email Address</label>
          <input type="email" id="email" name="email" required placeholder="john@example.com"
            style="width:100%;padding:13px 16px;border:2px solid #e5e7eb;border-radius:12px;font-size:14px;color:#1a1040;font-family:inherit;outline:none;transition:border-color 0.15s;box-sizing:border-box;"
            onfocus="this.style.borderColor='#7c3aed';" onblur="this.style.borderColor='#e5e7eb';" />
        </div>

        <div>
          <label for="subject" style="display:block;font-size:12px;font-weight:700;color:#374151;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">Topic</label>
          <select id="subject" name="subject"
            style="width:100%;padding:13px 16px;border:2px solid #e5e7eb;border-radius:12px;font-size:14px;color:#1a1040;font-family:inherit;outline:none;background:white;transition:border-color 0.15s;box-sizing:border-box;"
            onfocus="this.style.borderColor='#7c3aed';" onblur="this.style.borderColor='#e5e7eb';">
            <option value="">Select a topic...</option>
            <option value="question-error">Question Error / Correction</option>
            <option value="new-category">Suggest a New Category</option>
            <option value="general">General Question</option>
            <option value="feedback">Feedback</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div>
          <label for="message" style="display:block;font-size:12px;font-weight:700;color:#374151;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">Message</label>
          <textarea id="message" name="message" required rows="4" placeholder="Write your message here..."
            style="width:100%;padding:13px 16px;border:2px solid #e5e7eb;border-radius:12px;font-size:14px;color:#1a1040;font-family:inherit;outline:none;resize:none;transition:border-color 0.15s;box-sizing:border-box;"
            onfocus="this.style.borderColor='#7c3aed';" onblur="this.style.borderColor='#e5e7eb';"></textarea>
        </div>

        <button type="submit"
          style="width:100%;padding:15px;background:#1a1040;color:white;font-size:15px;font-weight:800;border-radius:100px;border:none;cursor:pointer;transition:background 0.15s;"
          onmouseover="this.style.background='#2d1b69';" onmouseout="this.style.background='#1a1040';">
          Send Message →
        </button>
      </form>

      <!-- Success -->
      <div id="form-success" style="display:none;text-align:center;padding:32px 16px;">
        <div style="font-size:48px;margin-bottom:12px;">✅</div>
        <h3 style="font-size:18px;font-weight:800;color:#1a1040;margin-bottom:6px;">Message sent!</h3>
        <p style="font-size:14px;color:#6b7280;">We'll get back to you within 24–48 hours.</p>
        <a href="/" style="display:inline-block;margin-top:16px;padding:12px 24px;background:#ffe66d;color:#1a1040;font-size:14px;font-weight:800;border-radius:100px;">← Back to Home</a>
      </div>
    </div>

  </main>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    form.style.display = 'none';
    success!.style.display = 'block';
  });
</script>
