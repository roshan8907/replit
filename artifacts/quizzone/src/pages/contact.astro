---
import Layout from '@layouts/Layout.astro';
---

<Layout
  title="Contact QuizZone — Get in Touch"
  description="Contact the QuizZone team with questions, suggestions, or feedback about our free online trivia quiz platform."
  canonical="/contact"
>
  <section class="bg-gradient-to-br from-gray-50 to-blue-50 border-b border-gray-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-14 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 mb-4">Contact Us</h1>
      <p class="text-lg text-gray-500">We'd love to hear from you. Drop us a message!</p>
    </div>
  </section>

  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-5 gap-10">
      <!-- Contact Info -->
      <aside class="md:col-span-2 space-y-6">
        <div>
          <h2 class="text-lg font-bold text-gray-900 mb-4">Get in Touch</h2>
          <p class="text-gray-500 text-sm leading-relaxed">
            Have a question about our quizzes, found a factual error, or want to suggest a new category? We're here to help.
          </p>
        </div>
        <div class="space-y-4">
          {[
            { icon: '✉️', label: 'Email', value: 'hello@quizzone.app' },
            { icon: '🐦', label: 'Twitter', value: '@QuizZoneApp' },
            { icon: '⏰', label: 'Response Time', value: 'Within 24–48 hours' },
          ].map((item) => (
            <div class="flex items-start gap-3">
              <span class="text-xl">{item.icon}</span>
              <div>
                <div class="text-xs text-gray-400 font-medium uppercase tracking-wide">{item.label}</div>
                <div class="text-sm text-gray-700 font-medium">{item.value}</div>
              </div>
            </div>
          ))}
        </div>
      </aside>

      <!-- Contact Form -->
      <div class="md:col-span-3">
        <form id="contact-form" class="space-y-5" novalidate>
          <div>
            <label for="name" class="block text-sm font-semibold text-gray-700 mb-1.5">Your Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="John Doe"
              class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-900 text-sm placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">Email Address</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="john@example.com"
              class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-900 text-sm placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            />
          </div>
          <div>
            <label for="subject" class="block text-sm font-semibold text-gray-700 mb-1.5">Subject</label>
            <select
              id="subject"
              name="subject"
              class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition bg-white"
            >
              <option value="">Select a topic...</option>
              <option value="question-error">Question Error / Correction</option>
              <option value="new-category">Suggest a New Category</option>
              <option value="general">General Question</option>
              <option value="feedback">Feedback</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-semibold text-gray-700 mb-1.5">Message</label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              placeholder="Write your message here..."
              class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-900 text-sm placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition resize-none"
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full px-6 py-3.5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl transition-colors shadow-md hover:shadow-lg text-sm"
          >
            Send Message →
          </button>
          <div id="form-success" class="hidden p-4 bg-green-50 border border-green-200 rounded-xl text-center">
            <p class="text-green-700 font-semibold">✅ Message sent! We'll get back to you within 24–48 hours.</p>
          </div>
        </form>
      </div>
    </div>
  </main>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    form.classList.add('hidden');
    success?.classList.remove('hidden');
  });
</script>
