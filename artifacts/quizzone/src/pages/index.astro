---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import questions from '@data/questions.json';

const categories = Object.entries(questions).map(([slug, cat]) => ({
  slug, name: cat.name, icon: cat.icon, description: cat.description, count: cat.questions.length,
}));

const categoryBg: Record<string, string> = {
  'general-knowledge': 'https://images.unsplash.com/photo-1456513080510-7bf3a84b82f8?w=400&q=80',
  'science-nature':    'https://images.unsplash.com/photo-1532187863486-abf9dbad1b69?w=400&q=80',
  'history':           'https://images.unsplash.com/photo-1461360370896-922624d12aa1?w=400&q=80',
  'geography':         'https://images.unsplash.com/photo-1526778548025-fa2f459cd5c1?w=400&q=80',
  'entertainment':     'https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?w=400&q=80',
  'sports':            'https://images.unsplash.com/photo-1461896836934-ffe607ba8211?w=400&q=80',
  'technology':        'https://images.unsplash.com/photo-1518770660439-4636190af475?w=400&q=80',
  'food-drink':        'https://images.unsplash.com/photo-1476718406336-bb5a9690ee2a?w=400&q=80',
};

const badgeColors: Record<string, string> = {
  'general-knowledge':'#f97316','science-nature':'#10b981','history':'#f59e0b',
  'geography':'#06b6d4','entertainment':'#a855f7','sports':'#ef4444',
  'technology':'#3b82f6','food-drink':'#ec4899',
};

const recentQuizzes = [
  { label: '2026 Hits & Missing Word',    slug: 'entertainment' },
  { label: 'World Capitals Lightning',    slug: 'geography' },
  { label: 'Sci-Fi Movie Quotes',         slug: 'entertainment' },
  { label: 'Ancient Civilizations',       slug: 'history' },
  { label: 'Elements & Symbols',          slug: 'science-nature' },
  { label: 'Olympic Records',             slug: 'sports' },
  { label: 'Famous Inventors',            slug: 'history' },
  { label: 'Streaming Era TV',            slug: 'entertainment' },
  { label: 'Coffee Around the World',     slug: 'food-drink' },
  { label: 'Tech Founders',               slug: 'technology' },
];
---

<Layout
  title="Free Online Trivia Quizzes | QuizZone"
  description="Play free online trivia quizzes on QuizZone. Choose from General Knowledge, History, Science, Geography, Sports and more — 10 questions, timed, 100% free."
>
  <Header />

  <main style="max-width:700px;margin:0 auto;padding:16px 16px 0;">

    <!-- Quick Quiz Cards (TOP) -->
    <div style="background:white;border-radius:20px;padding:14px;margin-bottom:14px;box-shadow:0 2px 12px rgba(0,0,0,0.08);">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">

        <!-- Free IQ Test -->
        <a href="/quiz/general-knowledge"
          style="background:#f0fdf4;border:1.5px solid #bbf7d0;border-radius:14px;padding:20px 12px 16px;display:flex;flex-direction:column;align-items:center;gap:10px;transition:all 0.18s;text-decoration:none;"
          onmouseover="this.style.borderColor='#22c55e';this.style.background='#dcfce7';"
          onmouseout="this.style.borderColor='#bbf7d0';this.style.background='#f0fdf4';">
          <svg width="52" height="52" viewBox="0 0 52 52" fill="none">
            <ellipse cx="26" cy="49" rx="14" ry="2.5" fill="rgba(0,0,0,0.07)"/>
            <!-- Brain outline -->
            <path d="M26 10C20 10 15 15 15 21C15 24 16 27 18 29C16.5 30 15.5 32 15.5 34C15.5 37.5 18 40 21 40H31C34 40 36.5 37.5 36.5 34C36.5 32 35.5 30 34 29C36 27 37 24 37 21C37 15 32 10 26 10Z" fill="#22c55e"/>
            <path d="M26 10C20 10 15 15 15 21C15 24 16 27 18 29C16.5 30 15.5 32 15.5 34C15.5 37.5 18 40 21 40H31C34 40 36.5 37.5 36.5 34C36.5 32 35.5 30 34 29C36 27 37 24 37 21C37 15 32 10 26 10Z" fill="url(#brainGrad)"/>
            <!-- Brain crease lines -->
            <path d="M26 14 C26 18 22 20 22 24" stroke="rgba(255,255,255,0.5)" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <path d="M26 14 C26 18 30 20 30 24" stroke="rgba(255,255,255,0.5)" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <path d="M19 27 C22 26 24 28 26 27 C28 26 30 26 33 27" stroke="rgba(255,255,255,0.5)" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <!-- IQ text -->
            <text x="26" y="35" text-anchor="middle" font-size="9" font-weight="900" fill="white" font-family="system-ui">IQ</text>
            <defs>
              <linearGradient id="brainGrad" x1="15" y1="10" x2="37" y2="40" gradientUnits="userSpaceOnUse">
                <stop stop-color="#4ade80"/>
                <stop offset="1" stop-color="#16a34a"/>
              </linearGradient>
            </defs>
          </svg>
          <span style="font-size:13px;font-weight:800;color:#1a1040;text-align:center;">Free IQ Test</span>
        </a>

        <!-- Personality Quiz -->
        <a href="/quiz/science-nature"
          style="background:#fdf4ff;border:1.5px solid #e9d5ff;border-radius:14px;padding:20px 12px 16px;display:flex;flex-direction:column;align-items:center;gap:10px;transition:all 0.18s;text-decoration:none;"
          onmouseover="this.style.borderColor='#a855f7';this.style.background='#f3e8ff';"
          onmouseout="this.style.borderColor='#e9d5ff';this.style.background='#fdf4ff';">
          <svg width="52" height="52" viewBox="0 0 52 52" fill="none">
            <ellipse cx="26" cy="49" rx="14" ry="2.5" fill="rgba(0,0,0,0.07)"/>
            <!-- Mirror frame -->
            <ellipse cx="26" cy="22" rx="11" ry="13" fill="url(#mirrorGrad)"/>
            <ellipse cx="26" cy="22" rx="9" ry="11" fill="#f0e6ff"/>
            <!-- Mirror reflection (face) -->
            <circle cx="26" cy="19" r="4" fill="#c4b5fd"/>
            <path d="M20 29 Q26 26 32 29" fill="#c4b5fd"/>
            <!-- Mirror handle -->
            <rect x="23" y="35" width="6" height="8" rx="3" fill="url(#mirrorGrad)"/>
            <!-- Stars around mirror -->
            <circle cx="14" cy="13" r="1.5" fill="#f0abfc"/>
            <circle cx="38" cy="16" r="1.2" fill="#f0abfc"/>
            <circle cx="36" cy="10" r="1" fill="#d8b4fe"/>
            <defs>
              <linearGradient id="mirrorGrad" x1="15" y1="9" x2="37" y2="43" gradientUnits="userSpaceOnUse">
                <stop stop-color="#c084fc"/>
                <stop offset="1" stop-color="#7c3aed"/>
              </linearGradient>
            </defs>
          </svg>
          <span style="font-size:13px;font-weight:800;color:#1a1040;text-align:center;">Personality Quiz</span>
        </a>

        <!-- Memory Challenge -->
        <a href="/quiz/history"
          style="background:#fefce8;border:1.5px solid #fde68a;border-radius:14px;padding:20px 12px 16px;display:flex;flex-direction:column;align-items:center;gap:10px;transition:all 0.18s;text-decoration:none;"
          onmouseover="this.style.borderColor='#f59e0b';this.style.background='#fef9c3';"
          onmouseout="this.style.borderColor='#fde68a';this.style.background='#fefce8';">
          <svg width="52" height="52" viewBox="0 0 52 52" fill="none">
            <ellipse cx="26" cy="49" rx="14" ry="2.5" fill="rgba(0,0,0,0.07)"/>
            <!-- Bulb glow -->
            <ellipse cx="26" cy="24" rx="12" ry="12" fill="rgba(250,204,21,0.25)"/>
            <!-- Bulb body -->
            <path d="M20 24C20 20.1 22.7 17 26 17C29.3 17 32 20.1 32 24C32 26.8 30.5 29.2 28.3 30.5L28 32H24L23.7 30.5C21.5 29.2 20 26.8 20 24Z" fill="url(#bulbGrad)"/>
            <!-- Bulb base rings -->
            <rect x="23" y="32" width="6" height="2.5" rx="1.5" fill="#d97706"/>
            <rect x="23.5" y="35" width="5" height="2.5" rx="1.5" fill="#b45309"/>
            <!-- Shine on bulb -->
            <ellipse cx="23" cy="21" rx="2.5" ry="3.5" fill="rgba(255,255,255,0.45)" transform="rotate(-20,23,21)"/>
            <!-- Rays -->
            <line x1="26" y1="10" x2="26" y2="13" stroke="#fbbf24" stroke-width="2" stroke-linecap="round"/>
            <line x1="34" y1="13" x2="32" y2="15" stroke="#fbbf24" stroke-width="2" stroke-linecap="round"/>
            <line x1="18" y1="13" x2="20" y2="15" stroke="#fbbf24" stroke-width="2" stroke-linecap="round"/>
            <line x1="37" y1="24" x2="34" y2="24" stroke="#fbbf24" stroke-width="2" stroke-linecap="round"/>
            <line x1="15" y1="24" x2="18" y2="24" stroke="#fbbf24" stroke-width="2" stroke-linecap="round"/>
            <defs>
              <linearGradient id="bulbGrad" x1="20" y1="17" x2="32" y2="35" gradientUnits="userSpaceOnUse">
                <stop stop-color="#fde047"/>
                <stop offset="1" stop-color="#f59e0b"/>
              </linearGradient>
            </defs>
          </svg>
          <span style="font-size:13px;font-weight:800;color:#1a1040;text-align:center;">Memory Challenge</span>
        </a>

        <!-- Speed Trivia -->
        <a href="/quiz/entertainment"
          style="background:#fff1f2;border:1.5px solid #fecdd3;border-radius:14px;padding:20px 12px 16px;display:flex;flex-direction:column;align-items:center;gap:10px;transition:all 0.18s;text-decoration:none;"
          onmouseover="this.style.borderColor='#ef4444';this.style.background='#ffe4e6';"
          onmouseout="this.style.borderColor='#fecdd3';this.style.background='#fff1f2';">
          <svg width="52" height="52" viewBox="0 0 52 52" fill="none">
            <ellipse cx="26" cy="49" rx="14" ry="2.5" fill="rgba(0,0,0,0.07)"/>
            <!-- Stopwatch body -->
            <circle cx="26" cy="28" r="15" fill="url(#watchGrad)"/>
            <circle cx="26" cy="28" r="15" stroke="#dc2626" stroke-width="1.5" fill="none"/>
            <circle cx="26" cy="28" r="12" fill="white"/>
            <!-- Crown / button -->
            <rect x="23" y="10" width="6" height="3.5" rx="2" fill="#ef4444"/>
            <rect x="24.5" y="9" width="3" height="2" rx="1" fill="#dc2626"/>
            <!-- Side button -->
            <rect x="37" y="16" width="4" height="3" rx="1.5" fill="#ef4444" transform="rotate(30,39,17)"/>
            <!-- Tick marks -->
            {[0,30,60,90,120,150,180,210,240,270,300,330].map((_,i) => null)}
            <line x1="26" y1="17" x2="26" y2="20" stroke="#e5e7eb" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="26" y1="36" x2="26" y2="39" stroke="#e5e7eb" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="14" y1="28" x2="17" y2="28" stroke="#e5e7eb" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="35" y1="28" x2="38" y2="28" stroke="#e5e7eb" stroke-width="1.5" stroke-linecap="round"/>
            <!-- Clock hands -->
            <line x1="26" y1="28" x2="26" y2="19" stroke="#1a1040" stroke-width="2" stroke-linecap="round"/>
            <line x1="26" y1="28" x2="32" y2="25" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="26" cy="28" r="2" fill="#1a1040"/>
            <!-- Speed lines -->
            <line x1="8" y1="23" x2="13" y2="23" stroke="#fca5a5" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="7" y1="28" x2="11" y2="28" stroke="#fca5a5" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="8" y1="33" x2="13" y2="33" stroke="#fca5a5" stroke-width="1.5" stroke-linecap="round"/>
            <defs>
              <linearGradient id="watchGrad" x1="11" y1="13" x2="41" y2="43" gradientUnits="userSpaceOnUse">
                <stop stop-color="#fca5a5"/>
                <stop offset="1" stop-color="#ef4444"/>
              </linearGradient>
            </defs>
          </svg>
          <span style="font-size:13px;font-weight:800;color:#1a1040;text-align:center;">Speed Trivia</span>
        </a>

      </div>
    </div>

    <!-- Top Banner Ad -->
    <div style="background:#ffd93d;border-radius:16px;padding:28px 16px;margin-bottom:16px;text-align:center;font-size:13px;font-weight:600;color:#92733a;">
      [TOP BANNER AD]
    </div>

    <!-- Quiz Categories header -->
    <div style="background:#1a1040;border-radius:16px;padding:16px 20px;margin-bottom:14px;text-align:center;">
      <h2 style="font-size:20px;font-weight:900;color:white;letter-spacing:0.2px;">Quiz Categories</h2>
    </div>

    <!-- Category cards — image backgrounds -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px;" class="cat-grid">
      {categories.map((cat) => (
        <a href={`/quiz/${cat.slug}`}
          style="display:block;border-radius:16px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.15);transition:all 0.18s;aspect-ratio:1/1;position:relative;"
          onmouseover="this.style.transform='scale(1.03)';this.style.boxShadow='0 10px 24px rgba(0,0,0,0.3)';"
          onmouseout="this.style.transform='scale(1)';this.style.boxShadow='0 2px 8px rgba(0,0,0,0.15)';">
          <!-- Background image with dark overlay -->
          <img
            src={categoryBg[cat.slug]}
            alt={cat.name}
            loading="lazy"
            style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;"/>
          <div style="position:absolute;inset:0;background:linear-gradient(to bottom, rgba(0,0,0,0.18) 0%, rgba(0,0,0,0.62) 100%);"></div>
          <!-- Category label top-left -->
          <div style="position:absolute;top:9px;left:9px;font-size:9px;font-weight:700;color:rgba(255,255,255,0.7);text-transform:uppercase;letter-spacing:0.5px;line-height:1.3;">{cat.name}</div>
          <!-- Icon badge top-right -->
          <div style={`position:absolute;top:7px;right:7px;width:30px;height:30px;border-radius:50%;background:${badgeColors[cat.slug]||'#f97316'};display:flex;align-items:center;justify-content:center;font-size:14px;box-shadow:0 2px 6px rgba(0,0,0,0.3);`}>{cat.icon}</div>
          <!-- Name at bottom -->
          <div style="position:absolute;bottom:0;left:0;right:0;padding:32px 12px 12px;background:linear-gradient(to top,rgba(0,0,0,0.85),transparent);">
            <div style="font-size:17px;font-weight:900;color:white;line-height:1.2;text-shadow:0 1px 4px rgba(0,0,0,0.5);">{cat.name}</div>
          </div>
        </a>
      ))}
    </div>

    <!-- Featured Quiz -->
    <a href="/quiz/general-knowledge"
      style="display:flex;align-items:center;gap:12px;background:white;border-radius:16px;padding:16px 18px;margin-bottom:12px;box-shadow:0 2px 8px rgba(0,0,0,0.08);transition:all 0.15s;"
      onmouseover="this.style.boxShadow='0 6px 16px rgba(0,0,0,0.12)';"
      onmouseout="this.style.boxShadow='0 2px 8px rgba(0,0,0,0.08)';">
      <div style="width:36px;height:36px;background:#1a1040;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#ffe66d" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 010 1.972l-11.54 6.347a1.125 1.125 0 01-1.667-.986V5.653z"/>
        </svg>
      </div>
      <span style="font-size:15px;font-weight:800;color:#1a1040;">▶ General Knowledge Quiz</span>
    </a>

    <!-- Recent Quizzes — fully clickable -->
    <div style="background:white;border-radius:16px;padding:18px;margin-bottom:16px;box-shadow:0 2px 8px rgba(0,0,0,0.08);">
      <h3 style="font-size:16px;font-weight:800;color:#1a1040;margin-bottom:14px;text-align:center;">Recent Quizzes</h3>
      <div style="display:flex;flex-direction:column;">
        {recentQuizzes.map((q, i) => (
          <a href={`/quiz/${q.slug}`}
            style={`display:flex;align-items:center;justify-content:space-between;padding:13px 4px;font-size:14px;font-weight:500;color:#1a1040;${i < recentQuizzes.length - 1 ? 'border-bottom:1px solid #f3f4f6;' : ''}transition:color 0.15s;`}
            onmouseover="this.style.color='#7c3aed';"
            onmouseout="this.style.color='#1a1040';">
            <span>{q.label}</span>
            <span style="font-size:12px;font-weight:700;color:#7c3aed;opacity:0.7;">Play →</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Sidebar Ad -->
    <div style="background:#ffd93d;border-radius:16px;padding:60px 16px;margin-bottom:16px;text-align:center;font-size:13px;font-weight:600;color:#92733a;">
      [SIDEBAR AD]
    </div>

    <!-- Features -->
    {[
      { emoji:'🎯', title:'Beat the clock',  desc:'20s per question keeps every quiz fast and addictive.' },
      { emoji:'📱', title:'Mobile-first',    desc:'Looks great on any device. Tap, swipe, score, share.' },
      { emoji:'💯', title:'Always free',     desc:'No paywalls, no sign-ups. Just pick a category and play.' },
    ].map((f) => (
      <div style="background:white;border-radius:16px;padding:18px 20px;margin-bottom:12px;box-shadow:0 2px 8px rgba(0,0,0,0.07);">
        <div style="font-size:15px;font-weight:800;color:#1a1040;display:flex;align-items:center;gap:8px;margin-bottom:6px;">
          <span style="font-size:20px;">{f.emoji}</span>{f.title}
        </div>
        <p style="font-size:13px;color:#6b7280;line-height:1.6;">{f.desc}</p>
      </div>
    ))}

    <!-- Footer Ad -->
    <div style="background:#ffd93d;border-radius:16px;padding:40px 16px;margin-bottom:24px;text-align:center;font-size:13px;font-weight:600;color:#92733a;">
      [FOOTER AD]
    </div>
  </main>

  <Footer />
</Layout>

<style>
  @media (min-width:540px){ .cat-grid{ grid-template-columns:repeat(3,1fr) !important; } }
  @media (min-width:700px){ .cat-grid{ grid-template-columns:repeat(4,1fr) !important; } }
</style>
