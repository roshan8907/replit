---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import questions from '@data/questions.json';

const categories = Object.entries(questions).map(([slug, cat]) => ({
  slug,
  name: cat.name,
  icon: cat.icon,
  description: cat.description,
  count: cat.questions.length,
}));

const gradients: Record<string, string> = {
  'general-knowledge': 'linear-gradient(135deg,#3b82f6,#1d4ed8)',
  'science-nature':    'linear-gradient(135deg,#10b981,#047857)',
  'history':           'linear-gradient(135deg,#f59e0b,#b45309)',
  'geography':         'linear-gradient(135deg,#06b6d4,#0e7490)',
  'entertainment':     'linear-gradient(135deg,#ec4899,#9333ea)',
  'sports':            'linear-gradient(135deg,#f97316,#c2410c)',
  'technology':        'linear-gradient(135deg,#6366f1,#4338ca)',
  'food-drink':        'linear-gradient(135deg,#ef4444,#b91c1c)',
};
---

<Layout
  title="Free Online Trivia Quizzes | QuizZone"
  description="Play free online trivia quizzes on QuizZone. Choose from General Knowledge, History, Science, Geography, Sports and more — 10 questions, instant scoring, completely free."
>
  <Header />

  <!-- Top Ad -->
  <div style="background:#f0f2f5;border-bottom:1px solid #e5e7eb;">
    <div style="max-width:960px;margin:0 auto;padding:8px 16px;">
      <div style="border:1px dashed #d1d5db;border-radius:6px;padding:10px;text-align:center;font-size:11px;color:#9ca3af;background:white;">
        [Advertisement — 728×90]
      </div>
    </div>
  </div>

  <!-- Page header -->
  <div style="background:linear-gradient(135deg,#2d1b69,#1e0a4e);padding:36px 16px 32px;text-align:center;">
    <h1 style="font-size:clamp(26px,5vw,42px);font-weight:900;color:white;letter-spacing:-0.5px;margin-bottom:10px;line-height:1.2;">
      Free Online <span style="color:#c084fc;">Trivia Quizzes</span>
    </h1>
    <p style="font-size:15px;color:rgba(255,255,255,0.65);max-width:440px;margin:0 auto;">
      Pick a category below and test your knowledge — 10 questions, timed, 100% free.
    </p>
  </div>

  <!-- Categories grid -->
  <main style="max-width:960px;margin:0 auto;padding:28px 16px 48px;">
    <h2 style="font-size:13px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:1px;margin-bottom:16px;">
      Quiz Categories
    </h2>

    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:14px;" class="cat-grid">
      {categories.map((cat) => (
        <a
          href={`/quiz/${cat.slug}`}
          style={`display:block;border-radius:12px;overflow:hidden;background:white;box-shadow:0 1px 4px rgba(0,0,0,0.08);transition:all 0.18s;text-decoration:none;`}
          onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 8px 24px rgba(0,0,0,0.13)';"
          onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 1px 4px rgba(0,0,0,0.08)';"
        >
          <!-- Gradient image area with icon -->
          <div style={`height:110px;background:${gradients[cat.slug] || 'linear-gradient(135deg,#6366f1,#4338ca)'};display:flex;align-items:center;justify-content:center;font-size:48px;`}>
            {cat.icon}
          </div>
          <!-- Card info -->
          <div style="padding:12px 14px 14px;">
            <div style="font-size:15px;font-weight:800;color:#111827;margin-bottom:3px;">{cat.name}</div>
            <div style="font-size:12px;color:#6b7280;line-height:1.5;margin-bottom:8px;">{cat.description}</div>
            <div style="display:flex;align-items:center;justify-content:space-between;">
              <span style="font-size:12px;color:#9ca3af;font-weight:500;">{cat.count} Questions</span>
              <span style="font-size:12px;font-weight:700;color:#7c3aed;">Play →</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Bottom Ad -->
    <div style="margin-top:32px;border:1px dashed #d1d5db;border-radius:8px;padding:12px;text-align:center;font-size:11px;color:#9ca3af;background:white;">
      [Advertisement — 728×90]
    </div>
  </main>

  <Footer />
</Layout>

<style>
  @media (min-width: 540px) {
    .cat-grid { grid-template-columns: repeat(3, 1fr) !important; }
  }
  @media (min-width: 800px) {
    .cat-grid { grid-template-columns: repeat(4, 1fr) !important; }
  }
</style>
