---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import questions from '@data/questions.json';

const categories = Object.entries(questions).map(([slug, cat]) => ({
  slug, name: cat.name, icon: cat.icon, description: cat.description, count: cat.questions.length,
}));

const categoryBg: Record<string, string> = {
  'general-knowledge': 'https://images.unsplash.com/photo-1456513080510-7bf3a84b82f8?w=400&q=80',
  'science-nature':    'https://images.unsplash.com/photo-1532187863486-abf9dbad1b69?w=400&q=80',
  'history':           'https://images.unsplash.com/photo-1461360370896-922624d12aa1?w=400&q=80',
  'geography':         'https://images.unsplash.com/photo-1526778548025-fa2f459cd5c1?w=400&q=80',
  'entertainment':     'https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?w=400&q=80',
  'sports':            'https://images.unsplash.com/photo-1461896836934-ffe607ba8211?w=400&q=80',
  'technology':        'https://images.unsplash.com/photo-1518770660439-4636190af475?w=400&q=80',
  'food-drink':        'https://images.unsplash.com/photo-1476718406336-bb5a9690ee2a?w=400&q=80',
};

const badgeColors: Record<string, string> = {
  'general-knowledge':'#f97316','science-nature':'#10b981','history':'#f59e0b',
  'geography':'#06b6d4','entertainment':'#a855f7','sports':'#ef4444',
  'technology':'#3b82f6','food-drink':'#ec4899',
};

const navCards = [
  { label: 'Home',       href: '/' },
  { label: 'Categories', href: '/categories' },
  { label: 'Blog',       href: '/blog' },
  { label: 'Contact',    href: '/contact' },
];

const recentQuizzes = [
  { label: '2026 Hits & Missing Word',    slug: 'entertainment' },
  { label: 'World Capitals Lightning',    slug: 'geography' },
  { label: 'Sci-Fi Movie Quotes',         slug: 'entertainment' },
  { label: 'Ancient Civilizations',       slug: 'history' },
  { label: 'Elements & Symbols',          slug: 'science-nature' },
  { label: 'Olympic Records',             slug: 'sports' },
  { label: 'Famous Inventors',            slug: 'history' },
  { label: 'Streaming Era TV',            slug: 'entertainment' },
  { label: 'Coffee Around the World',     slug: 'food-drink' },
  { label: 'Tech Founders',               slug: 'technology' },
];
---

<Layout
  title="Free Online Trivia Quizzes | QuizZone"
  description="Play free online trivia quizzes on QuizZone. Choose from General Knowledge, History, Science, Geography, Sports and more — 10 questions, timed, 100% free."
>
  <Header />

  <main style="max-width:700px;margin:0 auto;padding:16px 16px 0;">

    <!-- Nav Cards -->
    <div style="background:white;border-radius:20px;padding:14px;margin-bottom:16px;box-shadow:0 2px 12px rgba(0,0,0,0.08);">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">

        <!-- Home -->
        <a href="/"
          style="background:#f9fafb;border:1.5px solid #e5e7eb;border-radius:14px;padding:20px 12px 16px;display:flex;flex-direction:column;align-items:center;gap:10px;transition:all 0.18s;text-decoration:none;"
          onmouseover="this.style.borderColor='#f97316';this.style.background='#fff7ed';"
          onmouseout="this.style.borderColor='#e5e7eb';this.style.background='#f9fafb';">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
            <!-- House shadow -->
            <ellipse cx="24" cy="45" rx="14" ry="3" fill="rgba(0,0,0,0.08)"/>
            <!-- Roof -->
            <polygon points="24,6 42,22 6,22" fill="#f97316"/>
            <polygon points="24,6 42,22 38,22 24,10 10,22 6,22" fill="#fb923c"/>
            <!-- Chimney -->
            <rect x="30" y="10" width="5" height="8" rx="1" fill="#ea580c"/>
            <rect x="30" y="9" width="5" height="3" rx="1" fill="#f97316"/>
            <!-- Walls -->
            <rect x="10" y="21" width="28" height="22" rx="2" fill="#fed7aa"/>
            <rect x="10" y="21" width="28" height="4" fill="#fdba74"/>
            <!-- Door -->
            <rect x="20" y="30" width="8" height="13" rx="2" fill="#92400e"/>
            <rect x="20" y="30" width="8" height="13" rx="2" fill="url(#doorGrad)"/>
            <circle cx="27" cy="37" r="1.2" fill="#fbbf24"/>
            <!-- Window left -->
            <rect x="13" y="26" width="7" height="7" rx="1.5" fill="#bae6fd"/>
            <line x1="13" y1="29.5" x2="20" y2="29.5" stroke="white" stroke-width="1"/>
            <line x1="16.5" y1="26" x2="16.5" y2="33" stroke="white" stroke-width="1"/>
            <!-- Window right -->
            <rect x="28" y="26" width="7" height="7" rx="1.5" fill="#bae6fd"/>
            <line x1="28" y1="29.5" x2="35" y2="29.5" stroke="white" stroke-width="1"/>
            <line x1="31.5" y1="26" x2="31.5" y2="33" stroke="white" stroke-width="1"/>
            <defs>
              <linearGradient id="doorGrad" x1="20" y1="30" x2="28" y2="43" gradientUnits="userSpaceOnUse">
                <stop stop-color="#a16207"/>
                <stop offset="1" stop-color="#78350f"/>
              </linearGradient>
            </defs>
          </svg>
          <span style="font-size:14px;font-weight:800;color:#1a1040;">Home</span>
        </a>

        <!-- Categories -->
        <a href="/categories"
          style="background:#f9fafb;border:1.5px solid #e5e7eb;border-radius:14px;padding:20px 12px 16px;display:flex;flex-direction:column;align-items:center;gap:10px;transition:all 0.18s;text-decoration:none;"
          onmouseover="this.style.borderColor='#f59e0b';this.style.background='#fffbeb';"
          onmouseout="this.style.borderColor='#e5e7eb';this.style.background='#f9fafb';">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
            <ellipse cx="24" cy="45" rx="14" ry="3" fill="rgba(0,0,0,0.08)"/>
            <!-- Back folder (blue) -->
            <rect x="8" y="16" width="30" height="24" rx="3" fill="#3b82f6"/>
            <rect x="8" y="14" width="12" height="5" rx="2" fill="#2563eb"/>
            <!-- Mid folder (pink) -->
            <rect x="10" y="18" width="28" height="21" rx="3" fill="#f472b6"/>
            <rect x="10" y="16" width="11" height="5" rx="2" fill="#ec4899"/>
            <!-- Front folder (yellow) -->
            <rect x="7" y="20" width="34" height="22" rx="3" fill="#fbbf24"/>
            <rect x="7" y="18" width="13" height="5" rx="2.5" fill="#f59e0b"/>
            <!-- Folder shine -->
            <rect x="7" y="20" width="34" height="6" rx="3" fill="rgba(255,255,255,0.22)"/>
            <!-- Papers inside -->
            <rect x="13" y="28" width="22" height="2.5" rx="1.5" fill="rgba(255,255,255,0.7)"/>
            <rect x="13" y="32" width="16" height="2.5" rx="1.5" fill="rgba(255,255,255,0.5)"/>
          </svg>
          <span style="font-size:14px;font-weight:800;color:#1a1040;">Categories</span>
        </a>

        <!-- Blog -->
        <a href="/blog"
          style="background:#f9fafb;border:1.5px solid #e5e7eb;border-radius:14px;padding:20px 12px 16px;display:flex;flex-direction:column;align-items:center;gap:10px;transition:all 0.18s;text-decoration:none;"
          onmouseover="this.style.borderColor='#8b5cf6';this.style.background='#f5f3ff';"
          onmouseout="this.style.borderColor='#e5e7eb';this.style.background='#f9fafb';">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
            <ellipse cx="24" cy="45" rx="14" ry="3" fill="rgba(0,0,0,0.08)"/>
            <!-- Page shadow -->
            <rect x="11" y="9" width="26" height="34" rx="4" fill="#e2e8f0"/>
            <!-- Page -->
            <rect x="9" y="7" width="26" height="34" rx="4" fill="white"/>
            <rect x="9" y="7" width="26" height="34" rx="4" stroke="#e2e8f0" stroke-width="1"/>
            <!-- Lines -->
            <rect x="14" y="14" width="16" height="2.5" rx="1.5" fill="#c7d2fe"/>
            <rect x="14" y="19" width="16" height="2" rx="1" fill="#e2e8f0"/>
            <rect x="14" y="23" width="12" height="2" rx="1" fill="#e2e8f0"/>
            <rect x="14" y="27" width="14" height="2" rx="1" fill="#e2e8f0"/>
            <!-- Pencil -->
            <g transform="rotate(-40, 32, 32)">
              <rect x="28" y="22" width="6" height="18" rx="1" fill="#fbbf24"/>
              <polygon points="28,40 34,40 31,45" fill="#fde68a"/>
              <polygon points="29.5,43 31,45 32.5,43" fill="#1a1040"/>
              <rect x="28" y="22" width="6" height="4" rx="1" fill="#f87171"/>
              <rect x="28.5" y="22.5" width="1.5" height="15" rx="1" fill="rgba(255,255,255,0.35)"/>
            </g>
          </svg>
          <span style="font-size:14px;font-weight:800;color:#1a1040;">Blog</span>
        </a>

        <!-- Contact -->
        <a href="/contact"
          style="background:#f9fafb;border:1.5px solid #e5e7eb;border-radius:14px;padding:20px 12px 16px;display:flex;flex-direction:column;align-items:center;gap:10px;transition:all 0.18s;text-decoration:none;"
          onmouseover="this.style.borderColor='#06b6d4';this.style.background='#ecfeff';"
          onmouseout="this.style.borderColor='#e5e7eb';this.style.background='#f9fafb';">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
            <ellipse cx="24" cy="45" rx="14" ry="3" fill="rgba(0,0,0,0.08)"/>
            <!-- Envelope body shadow -->
            <rect x="7" y="14" width="34" height="26" rx="4" fill="#bae6fd"/>
            <!-- Envelope body -->
            <rect x="6" y="13" width="34" height="25" rx="4" fill="#e0f2fe"/>
            <!-- Envelope flap open crease -->
            <path d="M6 17 L23 27 L40 17" fill="none" stroke="#bae6fd" stroke-width="1.5"/>
            <!-- Envelope flap -->
            <path d="M6 13 Q6 13 23 24 Q40 13 40 13 L40 13 Q40 10 37 10 L11 10 Q8 10 6 13 Z" fill="#7dd3fc"/>
            <!-- V fold highlight -->
            <path d="M6 13 L23 24 L40 13" fill="none" stroke="white" stroke-width="1" stroke-opacity="0.5"/>
            <!-- Bottom corners -->
            <path d="M6 38 L20 26 M40 38 L26 26" stroke="#bae6fd" stroke-width="1.5" stroke-linecap="round"/>
            <!-- Letter lines inside -->
            <rect x="14" y="29" width="18" height="2" rx="1" fill="rgba(14,165,233,0.3)"/>
            <rect x="16" y="33" width="14" height="2" rx="1" fill="rgba(14,165,233,0.2)"/>
          </svg>
          <span style="font-size:14px;font-weight:800;color:#1a1040;">Contact</span>
        </a>

      </div>
    </div>

    <!-- Top Banner Ad -->
    <div style="background:#ffd93d;border-radius:16px;padding:28px 16px;margin-bottom:16px;text-align:center;font-size:13px;font-weight:600;color:#92733a;">
      [TOP BANNER AD]
    </div>

    <!-- Quiz Categories header -->
    <div style="background:#1a1040;border-radius:16px;padding:16px 20px;margin-bottom:14px;text-align:center;">
      <h2 style="font-size:20px;font-weight:900;color:white;letter-spacing:0.2px;">Quiz Categories</h2>
    </div>

    <!-- Category cards — image backgrounds -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px;" class="cat-grid">
      {categories.map((cat) => (
        <a href={`/quiz/${cat.slug}`}
          style="display:block;border-radius:16px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.15);transition:all 0.18s;aspect-ratio:1/1;position:relative;"
          onmouseover="this.style.transform='scale(1.03)';this.style.boxShadow='0 10px 24px rgba(0,0,0,0.3)';"
          onmouseout="this.style.transform='scale(1)';this.style.boxShadow='0 2px 8px rgba(0,0,0,0.15)';">
          <!-- Background image with dark overlay -->
          <img
            src={categoryBg[cat.slug]}
            alt={cat.name}
            loading="lazy"
            style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;"/>
          <div style="position:absolute;inset:0;background:linear-gradient(to bottom, rgba(0,0,0,0.18) 0%, rgba(0,0,0,0.62) 100%);"></div>
          <!-- Category label top-left -->
          <div style="position:absolute;top:9px;left:9px;font-size:9px;font-weight:700;color:rgba(255,255,255,0.7);text-transform:uppercase;letter-spacing:0.5px;line-height:1.3;">{cat.name}</div>
          <!-- Icon badge top-right -->
          <div style={`position:absolute;top:7px;right:7px;width:30px;height:30px;border-radius:50%;background:${badgeColors[cat.slug]||'#f97316'};display:flex;align-items:center;justify-content:center;font-size:14px;box-shadow:0 2px 6px rgba(0,0,0,0.3);`}>{cat.icon}</div>
          <!-- Name at bottom -->
          <div style="position:absolute;bottom:0;left:0;right:0;padding:32px 12px 12px;background:linear-gradient(to top,rgba(0,0,0,0.85),transparent);">
            <div style="font-size:17px;font-weight:900;color:white;line-height:1.2;text-shadow:0 1px 4px rgba(0,0,0,0.5);">{cat.name}</div>
          </div>
        </a>
      ))}
    </div>

    <!-- Featured Quiz -->
    <a href="/quiz/general-knowledge"
      style="display:flex;align-items:center;gap:12px;background:white;border-radius:16px;padding:16px 18px;margin-bottom:12px;box-shadow:0 2px 8px rgba(0,0,0,0.08);transition:all 0.15s;"
      onmouseover="this.style.boxShadow='0 6px 16px rgba(0,0,0,0.12)';"
      onmouseout="this.style.boxShadow='0 2px 8px rgba(0,0,0,0.08)';">
      <div style="width:36px;height:36px;background:#1a1040;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#ffe66d" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 010 1.972l-11.54 6.347a1.125 1.125 0 01-1.667-.986V5.653z"/>
        </svg>
      </div>
      <span style="font-size:15px;font-weight:800;color:#1a1040;">▶ General Knowledge Quiz</span>
    </a>

    <!-- Recent Quizzes — fully clickable -->
    <div style="background:white;border-radius:16px;padding:18px;margin-bottom:16px;box-shadow:0 2px 8px rgba(0,0,0,0.08);">
      <h3 style="font-size:16px;font-weight:800;color:#1a1040;margin-bottom:14px;text-align:center;">Recent Quizzes</h3>
      <div style="display:flex;flex-direction:column;">
        {recentQuizzes.map((q, i) => (
          <a href={`/quiz/${q.slug}`}
            style={`display:flex;align-items:center;justify-content:space-between;padding:13px 4px;font-size:14px;font-weight:500;color:#1a1040;${i < recentQuizzes.length - 1 ? 'border-bottom:1px solid #f3f4f6;' : ''}transition:color 0.15s;`}
            onmouseover="this.style.color='#7c3aed';"
            onmouseout="this.style.color='#1a1040';">
            <span>{q.label}</span>
            <span style="font-size:12px;font-weight:700;color:#7c3aed;opacity:0.7;">Play →</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Sidebar Ad -->
    <div style="background:#ffd93d;border-radius:16px;padding:60px 16px;margin-bottom:16px;text-align:center;font-size:13px;font-weight:600;color:#92733a;">
      [SIDEBAR AD]
    </div>

    <!-- Features -->
    {[
      { emoji:'🎯', title:'Beat the clock',  desc:'20s per question keeps every quiz fast and addictive.' },
      { emoji:'📱', title:'Mobile-first',    desc:'Looks great on any device. Tap, swipe, score, share.' },
      { emoji:'💯', title:'Always free',     desc:'No paywalls, no sign-ups. Just pick a category and play.' },
    ].map((f) => (
      <div style="background:white;border-radius:16px;padding:18px 20px;margin-bottom:12px;box-shadow:0 2px 8px rgba(0,0,0,0.07);">
        <div style="font-size:15px;font-weight:800;color:#1a1040;display:flex;align-items:center;gap:8px;margin-bottom:6px;">
          <span style="font-size:20px;">{f.emoji}</span>{f.title}
        </div>
        <p style="font-size:13px;color:#6b7280;line-height:1.6;">{f.desc}</p>
      </div>
    ))}

    <!-- Footer Ad -->
    <div style="background:#ffd93d;border-radius:16px;padding:40px 16px;margin-bottom:24px;text-align:center;font-size:13px;font-weight:600;color:#92733a;">
      [FOOTER AD]
    </div>
  </main>

  <Footer />
</Layout>

<style>
  @media (min-width:540px){ .cat-grid{ grid-template-columns:repeat(3,1fr) !important; } }
  @media (min-width:700px){ .cat-grid{ grid-template-columns:repeat(4,1fr) !important; } }
</style>
