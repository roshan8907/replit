---
import Layout from '@layouts/Layout.astro';
import CategoryCard from '@components/CategoryCard.astro';
import AdPlaceholder from '@components/AdPlaceholder.astro';
import questions from '@data/questions.json';

const categories = Object.entries(questions).map(([slug, cat]) => ({
  slug,
  name: cat.name,
  icon: cat.icon,
  color: cat.color,
  description: cat.description,
  quizCount: cat.quizCount,
  questionCount: cat.questions.length,
}));

const stats = [
  { label: 'Free Quizzes', value: '100+' },
  { label: 'Categories', value: `${categories.length}` },
  { label: 'Players Worldwide', value: '50K+' },
  { label: 'Questions', value: '800+' },
];
---

<Layout
  title="Free Online Trivia Quiz | QuizZone"
  description="Play free online trivia quizzes covering general knowledge, history, science, geography, entertainment, sports, and more. Test your knowledge on QuizZone!"
>
  <!-- Top Banner Ad -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6">
    <AdPlaceholder type="banner" />
  </div>

  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-blue-600 via-blue-700 to-indigo-800 text-white" aria-label="Hero">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-10 left-10 w-64 h-64 bg-white rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-10 w-80 h-80 bg-indigo-300 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28 text-center">
      <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm border border-white/20 text-white/90 text-sm font-medium px-4 py-2 rounded-full mb-6">
        <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
        100+ free quizzes available
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6 leading-tight">
        Free Online<br class="hidden sm:block" />
        <span class="text-yellow-300">Trivia Quiz</span>
      </h1>
      <p class="text-lg sm:text-xl text-blue-100 max-w-2xl mx-auto mb-10 leading-relaxed">
        Test your knowledge with fun quizzes across multiple categories. Challenge yourself, learn new facts, and compete for the top score.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/categories"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-blue-700 font-bold rounded-2xl shadow-xl hover:shadow-2xl hover:-translate-y-0.5 transition-all text-lg"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 010 1.972l-11.54 6.347a1.125 1.125 0 01-1.667-.986V5.653z" />
          </svg>
          Start Quiz
        </a>
        <a
          href="/about"
          class="inline-flex items-center justify-center px-8 py-4 bg-white/10 hover:bg-white/20 backdrop-blur-sm border border-white/20 text-white font-semibold rounded-2xl transition-all text-lg"
        >
          Learn More
        </a>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 mt-16 max-w-3xl mx-auto">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="text-3xl sm:text-4xl font-extrabold text-white">{stat.value}</div>
            <div class="text-sm text-blue-200 mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Categories Section -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20" aria-label="Quiz Categories">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-4">Browse Categories</h2>
      <p class="text-lg text-gray-500 max-w-xl mx-auto">
        Choose from our wide range of trivia categories. Something for everyone!
      </p>
    </div>

    <!-- In-Content Ad -->
    <div class="flex justify-center mb-10">
      <AdPlaceholder type="content" />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      {categories.map((cat) => (
        <CategoryCard {...cat} />
      ))}
    </div>

    <div class="text-center mt-10">
      <a
        href="/categories"
        class="inline-flex items-center gap-2 px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl transition-colors shadow-md hover:shadow-lg"
      >
        View All Categories
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- How It Works -->
  <section class="bg-gray-50 py-16 sm:py-20" aria-label="How It Works">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-4">How It Works</h2>
        <p class="text-lg text-gray-500">Start playing in just three easy steps.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { step: '01', title: 'Choose a Category', desc: 'Browse our wide selection of trivia categories and pick the one you enjoy most.', icon: '🎯' },
          { step: '02', title: 'Answer Questions', desc: 'Answer 10 carefully crafted questions within the time limit. Use your knowledge!', icon: '⚡' },
          { step: '03', title: 'Get Your Score', desc: 'See your final score, review your answers, and share your results with friends.', icon: '🏆' },
        ].map((item) => (
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center hover:shadow-md transition-shadow">
            <div class="text-4xl mb-4">{item.icon}</div>
            <div class="text-xs font-bold text-blue-600 tracking-widest uppercase mb-2">Step {item.step}</div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">{item.title}</h3>
            <p class="text-gray-500 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Leaderboard Ad -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <AdPlaceholder type="leaderboard" />
  </div>

  <!-- Featured Blog Teasers -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16" aria-label="Latest from Blog">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-10">
      <div>
        <h2 class="text-3xl font-extrabold text-gray-900 mb-2">Latest Articles</h2>
        <p class="text-gray-500">Tips, trivia facts, and quiz guides for curious minds.</p>
      </div>
      <a href="/blog" class="text-blue-600 font-semibold hover:underline shrink-0">View all →</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { title: 'The Best General Knowledge Quiz Questions for 2024', slug: 'best-general-knowledge-questions', date: 'Jun 1, 2024', category: 'General Knowledge', readTime: '5 min' },
        { title: 'Top 20 Geography Quiz Questions You Must Try', slug: 'top-geography-quiz-questions', date: 'May 20, 2024', category: 'Geography', readTime: '4 min' },
        { title: 'Science Quiz Questions Every Student Should Know', slug: 'science-quiz-for-students', date: 'May 8, 2024', category: 'Science', readTime: '6 min' },
      ].map((post) => (
        <a href={`/blog/${post.slug}`} class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all overflow-hidden">
          <div class="bg-gradient-to-br from-blue-50 to-indigo-50 h-32 flex items-center justify-center text-5xl group-hover:scale-105 transition-transform duration-300">
            📖
          </div>
          <div class="p-5">
            <div class="flex items-center gap-2 text-xs text-gray-400 mb-2">
              <span class="bg-blue-50 text-blue-600 font-medium px-2 py-0.5 rounded">{post.category}</span>
              <span>{post.date}</span>
              <span>·</span>
              <span>{post.readTime} read</span>
            </div>
            <h3 class="font-bold text-gray-900 group-hover:text-blue-600 transition-colors leading-snug">{post.title}</h3>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
