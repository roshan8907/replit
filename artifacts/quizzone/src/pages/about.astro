---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
---

<Layout
  title="About QuizZone — Free Trivia Quizzes Online"
  description="Learn about QuizZone, the free online trivia quiz platform. Our mission is to make learning fun with engaging quizzes across dozens of categories. No sign-ups, no paywalls."
  canonical="/about"
>
  <Header />

  <main style="max-width:700px;margin:0 auto;padding:16px 16px 32px;">

    <!-- Back button -->
    <a href="/" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:700;color:#92733a;margin-bottom:14px;padding:8px 14px;background:rgba(255,255,255,0.6);border-radius:100px;">
      ← Home
    </a>

    <!-- Hero -->
    <div style="background:#1a1040;border-radius:20px;padding:32px 20px 28px;text-align:center;margin-bottom:16px;">
      <div style="font-size:52px;margin-bottom:12px;">❓</div>
      <h1 style="font-size:26px;font-weight:900;color:white;margin-bottom:8px;">About QuizZone</h1>
      <p style="font-size:14px;color:rgba(255,255,255,0.65);max-width:320px;margin:0 auto;line-height:1.6;">Making learning fun, one quiz at a time — completely free, no sign-up required.</p>
    </div>

    <!-- Mission -->
    <div style="background:white;border-radius:16px;padding:22px 20px;margin-bottom:12px;box-shadow:0 2px 8px rgba(0,0,0,0.07);">
      <h2 style="font-size:17px;font-weight:800;color:#1a1040;margin-bottom:10px;display:flex;align-items:center;gap:8px;">🎯 Our Mission</h2>
      <p style="font-size:14px;color:#6b7280;line-height:1.7;">
        QuizZone was built with a simple goal: to make learning fun, accessible, and free for everyone. Whether you're brushing up on history, prepping for trivia night, or just love a good brain challenge — QuizZone has you covered.
      </p>
    </div>

    <!-- Features grid -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px;">
      {[
        ['🆓','100% Free','No subscriptions, no paywalls, no hidden fees ever.'],
        ['📚','8+ Categories','General Knowledge, Science, History, Geography and more.'],
        ['⏱️','Timed','30 seconds per question keeps things fast and exciting.'],
        ['📱','Mobile-first','Play on any device — phone, tablet, or desktop.'],
        ['🏆','Score tracking','Instant feedback and detailed score breakdown.'],
        ['🌍','Always growing','New questions and categories added regularly.'],
      ].map(([ic, t, d]) => (
        <div style="background:white;border-radius:14px;padding:16px;box-shadow:0 2px 8px rgba(0,0,0,0.07);display:flex;flex-direction:column;gap:6px;">
          <span style="font-size:24px;">{ic}</span>
          <div style="font-size:13px;font-weight:800;color:#1a1040;">{t}</div>
          <div style="font-size:12px;color:#6b7280;line-height:1.5;">{d}</div>
        </div>
      ))}
    </div>

    <!-- Team -->
    <div style="background:white;border-radius:16px;padding:22px 20px;margin-bottom:12px;box-shadow:0 2px 8px rgba(0,0,0,0.07);">
      <h2 style="font-size:17px;font-weight:800;color:#1a1040;margin-bottom:10px;display:flex;align-items:center;gap:8px;">👥 Our Team</h2>
      <p style="font-size:14px;color:#6b7280;line-height:1.7;margin-bottom:10px;">
        QuizZone is built by a passionate team of trivia lovers, educators, and developers who believe knowledge should be fun to acquire.
      </p>
      <p style="font-size:14px;color:#6b7280;line-height:1.7;">
        Every question is researched, fact-checked, and comes with an explanation so you learn even when you get it wrong.
      </p>
    </div>

    <!-- CTA -->
    <div style="background:#1a1040;border-radius:20px;padding:28px 20px;text-align:center;margin-bottom:16px;">
      <h2 style="font-size:18px;font-weight:900;color:white;margin-bottom:8px;">Want to get in touch?</h2>
      <p style="font-size:13px;color:rgba(255,255,255,0.6);margin-bottom:20px;">Have a question, suggestion, or found an error? We'd love to hear from you.</p>
      <div style="display:flex;flex-direction:column;gap:10px;">
        <a href="/contact"
          style="display:block;padding:14px;background:#ffe66d;color:#1a1040;font-size:14px;font-weight:800;border-radius:100px;text-align:center;transition:background 0.15s;"
          onmouseover="this.style.background='#ffd93d';" onmouseout="this.style.background='#ffe66d';">
          ✉️ Contact Us
        </a>
        <a href="/"
          style="display:block;padding:14px;background:rgba(255,255,255,0.1);color:white;font-size:14px;font-weight:700;border-radius:100px;text-align:center;transition:background 0.15s;"
          onmouseover="this.style.background='rgba(255,255,255,0.15)';" onmouseout="this.style.background='rgba(255,255,255,0.1)';">
          🎯 Start Playing
        </a>
      </div>
    </div>

  </main>

  <Footer />
</Layout>
