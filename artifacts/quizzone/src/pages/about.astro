---
import Layout from '@layouts/Layout.astro';
---

<Layout
  title="About QuizZone — Free Trivia Quizzes Online"
  description="Learn about QuizZone, the free online trivia quiz platform. Our mission is to make learning fun with engaging quizzes across dozens of categories."
  canonical="/about"
>
  <section class="bg-gradient-to-br from-gray-50 to-blue-50 border-b border-gray-100" aria-label="Page header">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-14 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 mb-4">About QuizZone</h1>
      <p class="text-lg text-gray-500">Making learning fun, one quiz at a time.</p>
    </div>
  </section>

  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <article class="prose prose-gray prose-lg max-w-none">
      <section aria-label="Our Mission">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Our Mission</h2>
        <p class="text-gray-600 leading-relaxed mb-6">
          QuizZone was created with a simple mission: to make learning fun, accessible, and free for everyone. Whether you're a student brushing up on history, a trivia night enthusiast, or simply someone who loves a good brain challenge, QuizZone has something for you.
        </p>
      </section>

      <section aria-label="What We Offer">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">What We Offer</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
          {[
            { icon: '🆓', title: '100% Free', desc: 'All quizzes on QuizZone are completely free. No subscriptions, no hidden fees, no paywalls.' },
            { icon: '📚', title: '8+ Categories', desc: 'From General Knowledge to Technology, we cover a wide range of topics for all interests.' },
            { icon: '⏱️', title: 'Timed Challenges', desc: 'Each question comes with a 30-second timer to keep things exciting and test quick thinking.' },
            { icon: '📱', title: 'Mobile Friendly', desc: 'Play on any device — phone, tablet, or desktop. Fully responsive design.' },
            { icon: '🏆', title: 'Score Tracking', desc: 'Get instant feedback on your performance with detailed score breakdowns after each quiz.' },
            { icon: '🌍', title: 'Always Growing', desc: 'We regularly add new questions and categories to keep the content fresh and engaging.' },
          ].map((item) => (
            <div class="flex gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
              <span class="text-2xl flex-shrink-0">{item.icon}</span>
              <div>
                <h3 class="font-bold text-gray-900 mb-1">{item.title}</h3>
                <p class="text-sm text-gray-500 leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section aria-label="Our Team">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Our Team</h2>
        <p class="text-gray-600 leading-relaxed mb-4">
          QuizZone is built by a passionate team of trivia lovers, educators, and developers who believe that knowledge should be fun to acquire. We carefully curate every question to ensure accuracy, relevance, and an enjoyable experience.
        </p>
        <p class="text-gray-600 leading-relaxed mb-6">
          Our questions are researched and fact-checked before being added to the platform. Each question comes with a brief explanation to help you learn even when you get it wrong.
        </p>
      </section>

      <section aria-label="Contact Us" class="bg-blue-50 rounded-2xl p-8 text-center mt-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-3">Want to Get in Touch?</h2>
        <p class="text-gray-600 mb-6">Have a question, suggestion, or found an error? We'd love to hear from you.</p>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl transition-colors shadow-md"
        >
          Contact Us
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </section>
    </article>
  </main>
</Layout>
