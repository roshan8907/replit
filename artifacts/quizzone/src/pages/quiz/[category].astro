---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import questions from '@data/questions.json';

export async function getStaticPaths() {
  return Object.keys(questions).map((slug) => ({ params: { category: slug } }));
}

const { category } = Astro.params;
const categoryData = questions[category as keyof typeof questions];
if (!categoryData) return Astro.redirect('/categories');

const questionsJson = JSON.stringify(categoryData.questions);

const categoryBg: Record<string, string> = {
  'general-knowledge': 'https://images.unsplash.com/photo-1456513080510-7bf3a84b82f8?w=800&q=80',
  'science-nature':    'https://images.unsplash.com/photo-1532187863486-abf9dbad1b69?w=800&q=80',
  'history':           'https://images.unsplash.com/photo-1461360370896-922624d12aa1?w=800&q=80',
  'geography':         'https://images.unsplash.com/photo-1526778548025-fa2f459cd5c1?w=800&q=80',
  'entertainment':     'https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?w=800&q=80',
  'sports':            'https://images.unsplash.com/photo-1461896836934-ffe607ba8211?w=800&q=80',
  'technology':        'https://images.unsplash.com/photo-1518770660439-4636190af475?w=800&q=80',
  'food-drink':        'https://images.unsplash.com/photo-1476718406336-bb5a9690ee2a?w=800&q=80',
};
const heroBg = categoryBg[category] || categoryBg['general-knowledge'];

// Mascot per category
const mascot: Record<string, string> = {
  'general-knowledge': '🧙',
  'science-nature':    '🔬',
  'history':           '📜',
  'geography':         '🌍',
  'entertainment':     '🎬',
  'sports':            '🏅',
  'technology':        '🤖',
  'food-drink':        '👨‍🍳',
};
const catMascot = mascot[category] || '🦉';
---

<Layout
  title={`${categoryData.name} Trivia Quiz — 10 Questions | QuizZone`}
  description={`Play the ${categoryData.name} quiz on QuizZone. ${categoryData.description} 10 questions with timer and instant scoring — free, no sign-up!`}
>
  <Header />

  <main style="max-width:700px;margin:0 auto;padding:16px 16px 32px;">

    <!-- INTRO -->
    <div id="intro" class="fade-in">
      <div style="font-size:12px;color:#92733a;margin-bottom:14px;display:flex;align-items:center;gap:4px;flex-wrap:wrap;">
        <a href="/" style="color:#92733a;font-weight:600;">Home</a>
        <span>›</span>
        <a href="/categories" style="color:#92733a;font-weight:600;">Categories</a>
        <span>›</span>
        <span style="font-weight:700;">{categoryData.name}</span>
      </div>

      <div style="border-radius:20px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,0.2);margin-bottom:16px;position:relative;">
        <img src={heroBg} alt={`${categoryData.name} trivia quiz`} loading="eager"
          style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" />
        <div style="position:absolute;inset:0;background:rgba(10,5,40,0.72);"></div>
        <div style="position:relative;padding:32px 20px 28px;text-align:center;">
          <div style="font-size:54px;margin-bottom:12px;filter:drop-shadow(0 2px 8px rgba(0,0,0,0.5));">{categoryData.icon}</div>
          <h1 style="font-size:26px;font-weight:900;color:white;margin-bottom:8px;text-shadow:0 2px 8px rgba(0,0,0,0.5);">{categoryData.name} Quiz</h1>
          <p style="font-size:14px;color:rgba(255,255,255,0.75);max-width:320px;margin:0 auto 24px;line-height:1.6;">{categoryData.description}</p>
          <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:8px;margin-bottom:24px;">
            {[['❓','10 Questions'],['⏱️','30 sec / Q'],['🏆','Score tracking'],['🔊','Voice narration']].map(([ic,lb]) => (
              <div style="background:rgba(255,255,255,0.15);backdrop-filter:blur(8px);border-radius:100px;padding:7px 14px;font-size:12px;font-weight:600;color:white;display:flex;align-items:center;gap:5px;border:1px solid rgba(255,255,255,0.2);">
                <span>{ic}</span><span>{lb}</span>
              </div>
            ))}
          </div>
          <button id="start-btn"
            style="width:100%;padding:16px;background:#ffe66d;color:#1a1040;font-size:16px;font-weight:900;border-radius:100px;border:none;cursor:pointer;transition:all 0.15s;box-shadow:0 4px 14px rgba(255,230,109,0.4);"
            onmouseover="this.style.background='#ffd93d';this.style.transform='translateY(-1px)';"
            onmouseout="this.style.background='#ffe66d';this.style.transform='translateY(0)';">
            ▶ Start Quiz
          </button>
        </div>
      </div>

      <div style="background:white;border-radius:16px;padding:18px 20px;box-shadow:0 2px 8px rgba(0,0,0,0.06);">
        <h2 style="font-size:15px;font-weight:800;color:#1a1040;margin-bottom:8px;">About this quiz</h2>
        <p style="font-size:13px;color:#6b7280;line-height:1.7;">{categoryData.description} 10 questions, 30-second timer, instant explanations with voice narration — completely free.</p>
      </div>
    </div>

    <!-- QUIZ -->
    <div id="quiz" style="display:none;" class="fade-in">
      <div style="background:white;border-radius:20px;padding:20px;box-shadow:0 4px 16px rgba(0,0,0,0.1);">

        <!-- Top bar -->
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
          <div style="display:flex;align-items:center;gap:7px;font-size:14px;font-weight:700;color:#1a1040;">
            <span style="font-size:16px;">{categoryData.icon}</span>
            <span>Question <span id="q-num">1</span>/10</span>
          </div>
          <div style="display:flex;align-items:center;gap:8px;">
            <!-- Voice toggle -->
            <button id="voice-btn" title="Toggle voice narration"
              style="background:#f3f4f6;border:none;padding:6px 10px;border-radius:100px;font-size:14px;cursor:pointer;transition:all 0.15s;"
              onmouseover="this.style.background='#e5e7eb';" onmouseout="this.style.background='#f3f4f6';">
              🔊
            </button>
            <div id="timer-pill" style="background:#1a1040;color:white;font-size:13px;font-weight:800;padding:6px 14px;border-radius:100px;display:flex;align-items:center;gap:5px;min-width:72px;justify-content:center;transition:background 0.3s;">
              ⏱ <span id="timer-val">30</span>s
            </div>
          </div>
        </div>

        <!-- Progress bar -->
        <div style="height:5px;background:#f3f4f6;border-radius:100px;overflow:hidden;margin-bottom:22px;">
          <div id="prog-bar" style="height:100%;background:#ffe66d;border-radius:100px;transition:width 0.4s ease;width:10%;"></div>
        </div>

        <!-- Question text -->
        <p id="q-text" style="font-size:19px;font-weight:800;color:#1a1040;line-height:1.45;text-align:center;min-height:64px;margin-bottom:22px;display:flex;align-items:center;justify-content:center;"></p>

        <!-- Options -->
        <div id="opts" style="display:flex;flex-direction:column;gap:10px;margin-bottom:18px;"></div>

        <!-- Explanation with 3D mascot -->
        <div id="explain" style="display:none;margin-bottom:14px;">
          <!-- Mascot character bubble -->
          <div style="display:flex;align-items:flex-end;gap:10px;margin-bottom:8px;">
            <div class="mascot-wrap">
              <div class="mascot-char" id="mascot-emoji">{catMascot}</div>
              <div class="mascot-shadow"></div>
            </div>
            <!-- Speech bubble tail -->
            <div style="flex:1;background:#f0fdf4;border:2px solid #86efac;border-radius:16px 16px 16px 4px;padding:14px 16px;position:relative;">
              <div style="font-size:12px;font-weight:800;color:#166534;margin-bottom:5px;display:flex;align-items:center;gap:5px;">
                <span>💡</span> Explanation
              </div>
              <p id="explain-txt" style="font-size:13px;color:#15803d;line-height:1.7;margin:0;"></p>
            </div>
          </div>
        </div>

        <!-- Nav -->
        <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;">
          <button id="prev-btn"
            style="flex:1;padding:13px;background:white;border:2px solid #e5e7eb;border-radius:100px;font-size:14px;font-weight:700;color:#9ca3af;cursor:pointer;transition:all 0.15s;"
            disabled>← Previous</button>
          <button id="next-btn"
            style="display:none;flex:1;padding:13px;background:#ffe66d;border:none;border-radius:100px;font-size:14px;font-weight:800;color:#1a1040;cursor:pointer;transition:all 0.15s;"
            onmouseover="this.style.background='#ffd93d';" onmouseout="this.style.background='#ffe66d';">
            Next →
          </button>
          <button id="finish-btn"
            style="display:none;flex:1;padding:13px;background:#22c55e;border:none;border-radius:100px;font-size:14px;font-weight:800;color:white;cursor:pointer;transition:all 0.15s;"
            onmouseover="this.style.background='#16a34a';" onmouseout="this.style.background='#22c55e';">
            Finish ✓
          </button>
        </div>
      </div>

      <div style="background:#ffd93d;border-radius:16px;padding:50px 16px;margin-top:16px;text-align:center;font-size:13px;font-weight:600;color:#92733a;">[IN-CONTENT AD]</div>
      <div style="background:#ffd93d;border-radius:16px;padding:50px 16px;margin-top:12px;text-align:center;font-size:13px;font-weight:600;color:#92733a;">[FOOTER AD]</div>
    </div>

    <!-- RESULTS -->
    <div id="results" style="display:none;" class="pop-in">
      <div style="background:white;border-radius:20px;padding:28px 20px;text-align:center;box-shadow:0 4px 16px rgba(0,0,0,0.1);margin-bottom:16px;">
        <div id="res-emoji" style="font-size:60px;margin-bottom:12px;">🏆</div>
        <h2 style="font-size:24px;font-weight:900;color:#1a1040;margin-bottom:6px;">Quiz Complete!</h2>
        <p id="res-msg" style="font-size:14px;color:#6b7280;margin-bottom:24px;"></p>
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:22px;">
          <div style="background:#f5f3ff;border-radius:14px;padding:16px;"><div id="res-score" style="font-size:28px;font-weight:900;color:#7c3aed;"></div><div style="font-size:11px;font-weight:700;color:#7c3aed;margin-top:2px;">POINTS</div></div>
          <div style="background:#f0fdf4;border-radius:14px;padding:16px;"><div id="res-correct" style="font-size:28px;font-weight:900;color:#16a34a;"></div><div style="font-size:11px;font-weight:700;color:#16a34a;margin-top:2px;">CORRECT</div></div>
          <div style="background:#fef2f2;border-radius:14px;padding:16px;"><div id="res-wrong" style="font-size:28px;font-weight:900;color:#dc2626;"></div><div style="font-size:11px;font-weight:700;color:#dc2626;margin-top:2px;">WRONG</div></div>
          <div style="background:#fefce8;border-radius:14px;padding:16px;"><div id="res-pct" style="font-size:28px;font-weight:900;color:#ca8a04;"></div><div style="font-size:11px;font-weight:700;color:#ca8a04;margin-top:2px;">ACCURACY</div></div>
        </div>
        <div style="display:flex;flex-direction:column;gap:10px;">
          <button id="again-btn" style="width:100%;padding:15px;background:#1a1040;color:white;font-size:15px;font-weight:800;border-radius:100px;border:none;cursor:pointer;" onmouseover="this.style.background='#2d1b69';" onmouseout="this.style.background='#1a1040';">🔄 Play Again (new questions)</button>
          <a href="/categories" style="width:100%;padding:15px;background:#ffe66d;color:#1a1040;font-size:15px;font-weight:800;border-radius:100px;text-align:center;display:block;" onmouseover="this.style.background='#ffd93d';" onmouseout="this.style.background='#ffe66d';">🎯 Try Another Quiz</a>
          <button id="share-btn" style="width:100%;padding:15px;background:white;border:2px solid #e5e7eb;color:#1a1040;font-size:15px;font-weight:800;border-radius:100px;cursor:pointer;" onmouseover="this.style.borderColor='#1a1040';" onmouseout="this.style.borderColor='#e5e7eb';">🔗 Share Score</button>
        </div>
      </div>
      <div style="background:white;border-radius:20px;padding:20px;box-shadow:0 2px 8px rgba(0,0,0,0.08);">
        <h3 style="font-size:17px;font-weight:800;color:#1a1040;margin-bottom:16px;">Answer Review</h3>
        <div id="review" style="display:flex;flex-direction:column;gap:10px;"></div>
      </div>
    </div>

  </main>
  <Footer />
</Layout>

<style>
  /* ── Mascot 3D character ──────────────────────────────────────── */
  .mascot-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    gap: 3px;
  }
  .mascot-char {
    font-size: 48px;
    display: block;
    animation: mascotBob 1.8s ease-in-out infinite;
    filter: drop-shadow(0 8px 12px rgba(0,0,0,0.22)) drop-shadow(0 2px 4px rgba(0,0,0,0.15));
    transform-origin: bottom center;
    cursor: default;
    user-select: none;
  }
  .mascot-shadow {
    width: 36px;
    height: 8px;
    background: radial-gradient(ellipse, rgba(0,0,0,0.18) 0%, transparent 70%);
    border-radius: 50%;
    animation: shadowPulse 1.8s ease-in-out infinite;
  }
  @keyframes mascotBob {
    0%,100% { transform: translateY(0) rotate(-3deg) scale(1);   }
    25%      { transform: translateY(-7px) rotate(3deg) scale(1.04); }
    50%      { transform: translateY(-10px) rotate(0deg) scale(1.06); }
    75%      { transform: translateY(-5px) rotate(-2deg) scale(1.02); }
  }
  @keyframes shadowPulse {
    0%,100% { transform: scaleX(1);   opacity: 0.7; }
    50%      { transform: scaleX(0.65); opacity: 0.3; }
  }

  @keyframes pulse {
    0%,100% { transform: scale(1); }
    50% { transform: scale(1.06); }
  }
  @keyframes fadeIn  { from { opacity:0; transform:translateY(6px) } to { opacity:1; transform:translateY(0) } }
  @keyframes popIn   { from { opacity:0; transform:scale(0.94) } to { opacity:1; transform:scale(1) } }
  .fade-in { animation: fadeIn 0.3s ease both; }
  .pop-in  { animation: popIn  0.25s ease both; }
</style>

<script define:vars={{ questionsJson, categoryName: categoryData.name }}>
  const ALL_QS = JSON.parse(questionsJson);
  const TOTAL = 10;
  const TIME  = 30;

  // ── Voice narration ──────────────────────────────────────────────────────
  let voiceEnabled = true;

  function speak(text) {
    if (!voiceEnabled || !('speechSynthesis' in window)) return;
    window.speechSynthesis.cancel();
    const u = new SpeechSynthesisUtterance(text);
    u.rate   = 0.92;
    u.pitch  = 1.05;
    u.volume = 1;
    // Prefer a clear English voice if available
    const voices = window.speechSynthesis.getVoices();
    const preferred = voices.find(v => v.lang.startsWith('en') && v.localService);
    if (preferred) u.voice = preferred;
    window.speechSynthesis.speak(u);
  }

  const voiceBtn = document.getElementById('voice-btn');
  voiceBtn?.addEventListener('click', () => {
    voiceEnabled = !voiceEnabled;
    voiceBtn.textContent = voiceEnabled ? '🔊' : '🔇';
    voiceBtn.style.background = voiceEnabled ? '#f3f4f6' : '#fee2e2';
    if (!voiceEnabled) window.speechSynthesis?.cancel();
  });

  // Load voices early (Chrome lazy-loads them)
  if ('speechSynthesis' in window) {
    window.speechSynthesis.getVoices();
    window.speechSynthesis.addEventListener('voiceschanged', () => window.speechSynthesis.getVoices());
  }

  // ── Sound engine ──────────────────────────────────────────────────────────
  let audioCtx = null;
  function getAudioCtx() {
    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    return audioCtx;
  }

  function playSound(type) {
    try {
      const ctx = getAudioCtx();
      if (ctx.state === 'suspended') ctx.resume();
      const now = ctx.currentTime;

      if (type === 'correct') {
        [[523,0],[659,0.1],[784,0.2],[1047,0.32]].forEach(([freq,t]) => {
          const o = ctx.createOscillator(), g = ctx.createGain();
          o.connect(g); g.connect(ctx.destination);
          o.type = 'sine'; o.frequency.value = freq;
          g.gain.setValueAtTime(0, now+t);
          g.gain.linearRampToValueAtTime(0.28, now+t+0.02);
          g.gain.exponentialRampToValueAtTime(0.001, now+t+0.25);
          o.start(now+t); o.stop(now+t+0.3);
        });
      } else if (type === 'wrong') {
        [[300,0],[220,0.08],[160,0.18]].forEach(([freq,t]) => {
          const o = ctx.createOscillator(), g = ctx.createGain();
          o.connect(g); g.connect(ctx.destination);
          o.type = 'sawtooth'; o.frequency.value = freq;
          g.gain.setValueAtTime(0.22, now+t);
          g.gain.exponentialRampToValueAtTime(0.001, now+t+0.18);
          o.start(now+t); o.stop(now+t+0.22);
        });
      } else if (type === 'tick_soft') {
        // Gentle tick for seconds 30..11
        const o = ctx.createOscillator(), g = ctx.createGain();
        o.connect(g); g.connect(ctx.destination);
        o.type = 'sine'; o.frequency.value = 660;
        g.gain.setValueAtTime(0.06, now);
        g.gain.exponentialRampToValueAtTime(0.001, now+0.055);
        o.start(now); o.stop(now+0.07);
      } else if (type === 'tick_mid') {
        // Sharper tick for seconds 10..6
        const o = ctx.createOscillator(), g = ctx.createGain();
        o.connect(g); g.connect(ctx.destination);
        o.type = 'triangle'; o.frequency.value = 880;
        g.gain.setValueAtTime(0.14, now);
        g.gain.exponentialRampToValueAtTime(0.001, now+0.07);
        o.start(now); o.stop(now+0.09);
      } else if (type === 'tick_urgent') {
        // Double beep for last 5 seconds
        [0, 0.11].forEach(t => {
          const o = ctx.createOscillator(), g = ctx.createGain();
          o.connect(g); g.connect(ctx.destination);
          o.type = 'square'; o.frequency.value = 680;
          g.gain.setValueAtTime(0.18, now+t);
          g.gain.exponentialRampToValueAtTime(0.001, now+t+0.09);
          o.start(now+t); o.stop(now+t+0.11);
        });
      } else if (type === 'finish') {
        [[392,0],[523,0.12],[659,0.24],[784,0.36],[1047,0.5]].forEach(([freq,t]) => {
          const o = ctx.createOscillator(), g = ctx.createGain();
          o.connect(g); g.connect(ctx.destination);
          o.type = 'sine'; o.frequency.value = freq;
          g.gain.setValueAtTime(0, now+t);
          g.gain.linearRampToValueAtTime(0.25, now+t+0.03);
          g.gain.exponentialRampToValueAtTime(0.001, now+t+0.35);
          o.start(now+t); o.stop(now+t+0.4);
        });
      }
    } catch(e) { /* ignore audio errors */ }
  }

  // ── Question shuffling ─────────────────────────────────────────────────────
  function shuffle(arr) {
    const a = [...arr];
    for (let i = a.length-1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i+1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function shuffleOptions(q) {
    const indexed = q.options.map((opt, i) => ({ opt, correct: i === q.correct }));
    const s = shuffle(indexed);
    return { ...q, options: s.map(x => x.opt), correct: s.findIndex(x => x.correct) };
  }

  function buildSession() {
    return shuffle(ALL_QS).slice(0, TOTAL).map(shuffleOptions);
  }

  // ── State ──────────────────────────────────────────────────────────────────
  let QS = buildSession();
  let idx = 0, score = 0, timeLeft = TIME, timerInt = null, startMs = 0;
  let answers = Array(TOTAL).fill(null);

  // ── DOM refs ───────────────────────────────────────────────────────────────
  const introEl    = document.getElementById('intro');
  const quizEl     = document.getElementById('quiz');
  const resEl      = document.getElementById('results');
  const startBtn   = document.getElementById('start-btn');
  const prevBtn    = document.getElementById('prev-btn');
  const nextBtn    = document.getElementById('next-btn');
  const finishBtn  = document.getElementById('finish-btn');
  const againBtn   = document.getElementById('again-btn');
  const shareBtn   = document.getElementById('share-btn');
  const qNum       = document.getElementById('q-num');
  const timerVal   = document.getElementById('timer-val');
  const timerPill  = document.getElementById('timer-pill');
  const progBar    = document.getElementById('prog-bar');
  const qText      = document.getElementById('q-text');
  const opts       = document.getElementById('opts');
  const explainEl  = document.getElementById('explain');
  const explainTxt = document.getElementById('explain-txt');
  const review     = document.getElementById('review');

  const show = el => { el.style.display = 'block'; };
  const hide = el => { el.style.display = 'none'; };

  // Unlock audio on first interaction
  document.addEventListener('click', () => {
    audioCtx && audioCtx.state === 'suspended' && audioCtx.resume();
  }, { once: true });

  startBtn.addEventListener('click', () => {
    hide(introEl); show(quizEl); startMs = Date.now(); render();
  });

  function render() {
    const q = QS[idx];
    const done = answers[idx] !== null;

    qNum.textContent  = idx + 1;
    progBar.style.width = ((idx + 1) / TOTAL * 100) + '%';
    qText.textContent = q.question;

    // Build option buttons
    opts.innerHTML = '';
    q.options.forEach((opt, i) => {
      const btn = document.createElement('button');
      btn.textContent = opt;
      btn.style.cssText = getOptStyle(i, done, q.correct, answers[idx]);
      if (!done) {
        btn.addEventListener('click', () => pick(i));
        btn.addEventListener('mouseenter', () => { if (answers[idx] === null) btn.style.background = '#2d1b69'; });
        btn.addEventListener('mouseleave', () => { if (answers[idx] === null) btn.style.background = '#1a1040'; });
      }
      opts.appendChild(btn);
    });

    if (done) {
      explainTxt.textContent = q.explanation;
      show(explainEl);
      stopTimer();
    } else {
      hide(explainEl);
      startTimer();
      // Speak the question aloud
      speak(`Question ${idx + 1}. ${q.question}`);
    }

    prevBtn.disabled = idx === 0;
    prevBtn.style.opacity = idx === 0 ? '0.35' : '1';
    prevBtn.style.color   = idx === 0 ? '#9ca3af' : '#1a1040';
    nextBtn.style.display   = (done && idx < TOTAL-1) ? 'block' : 'none';
    finishBtn.style.display = (done && idx === TOTAL-1) ? 'block' : 'none';
  }

  function getOptStyle(i, done, correct, picked) {
    const base = 'width:100%;padding:15px 18px;border-radius:100px;font-size:15px;font-weight:700;border:none;cursor:pointer;transition:background 0.18s;text-align:center;letter-spacing:0.1px;';
    if (!done) return base + 'background:#1a1040;color:white;';
    if (i === correct) return base + 'background:#22c55e;color:white;cursor:default;';
    if (i === picked && i !== correct) return base + 'background:#ef4444;color:white;cursor:default;';
    return base + 'background:#e5e7eb;color:#9ca3af;cursor:default;';
  }

  function pick(i) {
    if (answers[idx] !== null) return;
    stopTimer();
    window.speechSynthesis?.cancel();
    const q = QS[idx];
    answers[idx] = i;
    if (i === q.correct) {
      score += Math.max(5, timeLeft * 3);
      playSound('correct');
      setTimeout(() => speak('Correct! ' + q.explanation), 600);
    } else {
      playSound('wrong');
      const correctOpt = i === -1 ? q.options[q.correct] : q.options[q.correct];
      setTimeout(() => speak('Wrong. The correct answer is: ' + correctOpt + '. ' + q.explanation), 600);
    }
    render();
  }

  function startTimer() {
    stopTimer();
    timeLeft = TIME;
    updateTimer();
    // Play first tick immediately so user knows timer started
    playSound('tick_soft');
    timerInt = setInterval(() => {
      timeLeft--;
      updateTimer();
      // Tiered tick sounds from second 1
      if (timeLeft <= 5 && timeLeft > 0)        playSound('tick_urgent');
      else if (timeLeft <= 10 && timeLeft > 5)   playSound('tick_mid');
      else if (timeLeft > 0)                      playSound('tick_soft');
      if (timeLeft <= 0) { stopTimer(); pick(-1); }
    }, 1000);
  }

  function stopTimer() { clearInterval(timerInt); timerInt = null; }

  function updateTimer() {
    timerVal.textContent = timeLeft;
    timerPill.style.animation = 'none';
    if (timeLeft > 10) {
      timerPill.style.background = '#1a1040';
    } else if (timeLeft > 5) {
      timerPill.style.background = '#d97706';
    } else {
      timerPill.style.background = '#ef4444';
      timerPill.style.animation = 'pulse 0.5s ease infinite';
    }
  }

  prevBtn.addEventListener('click', () => {
    if (idx > 0) { stopTimer(); window.speechSynthesis?.cancel(); idx--; render(); }
  });
  nextBtn.addEventListener('click', () => {
    if (idx < TOTAL-1) { stopTimer(); window.speechSynthesis?.cancel(); idx++; render(); }
  });
  finishBtn.addEventListener('click', showResults);

  function showResults() {
    stopTimer();
    window.speechSynthesis?.cancel();
    playSound('finish');
    const correct = answers.filter((a,i) => a === QS[i].correct).length;
    const pct = Math.round(correct / TOTAL * 100);
    hide(quizEl); show(resEl);

    document.getElementById('res-score').textContent   = score;
    document.getElementById('res-correct').textContent = correct;
    document.getElementById('res-wrong').textContent   = TOTAL - correct;
    document.getElementById('res-pct').textContent     = pct + '%';

    const emoji = pct >= 90 ? '🏆' : pct >= 70 ? '🎉' : pct >= 50 ? '😊' : '💪';
    const msg   = pct >= 90 ? 'Outstanding! Perfect score!' : pct >= 70 ? 'Great job! Well done!' : pct >= 50 ? 'Not bad — keep practicing!' : "Don't give up, try again!";
    document.getElementById('res-emoji').textContent = emoji;
    document.getElementById('res-msg').textContent   = msg;
    setTimeout(() => speak(`Quiz complete! You scored ${correct} out of ${TOTAL}. ${msg}`), 800);

    review.innerHTML = '';
    QS.forEach((q,i) => {
      const ok = answers[i] === q.correct;
      const d  = document.createElement('div');
      d.style.cssText = `padding:14px;border-radius:12px;border:2px solid ${ok ? '#bbf7d0' : '#fecaca'};background:${ok ? '#f0fdf4' : '#fef2f2'};`;
      d.innerHTML = `<div style="display:flex;gap:10px;"><span style="font-size:16px;flex-shrink:0;">${ok ? '✅' : '❌'}</span><div><p style="font-size:13px;font-weight:700;color:#1a1040;margin-bottom:4px;">${i+1}. ${q.question}</p>${!ok && answers[i] >= 0 ? `<p style="font-size:12px;color:#dc2626;margin-bottom:3px;">Your answer: ${q.options[answers[i]]}</p>` : ''}${!ok ? `<p style="font-size:12px;color:#15803d;margin-bottom:3px;">✓ Correct: ${q.options[q.correct]}</p>` : ''}<p style="font-size:12px;color:#6b7280;line-height:1.5;">${q.explanation}</p></div></div>`;
      review.appendChild(d);
    });
  }

  againBtn.addEventListener('click', () => {
    window.speechSynthesis?.cancel();
    QS = buildSession();
    idx = 0; score = 0; answers = Array(TOTAL).fill(null); startMs = Date.now();
    hide(resEl); show(quizEl); render();
  });

  shareBtn.addEventListener('click', () => {
    const correct = answers.filter((a,i) => a === QS[i].correct).length;
    const pct = Math.round(correct / TOTAL * 100);
    const text = `I scored ${pct}% on the ${categoryName} quiz on QuizZone! 🧠 ${location.href}`;
    if (navigator.share) navigator.share({ title:'QuizZone', text, url: location.href });
    else navigator.clipboard?.writeText(text).then(() => {
      shareBtn.textContent = '✅ Copied!';
      setTimeout(() => { shareBtn.textContent = '🔗 Share Score'; }, 2000);
    });
  });
</script>
