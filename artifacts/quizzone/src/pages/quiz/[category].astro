---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import questions from '@data/questions.json';

export async function getStaticPaths() {
  return Object.keys(questions).map((slug) => ({ params: { category: slug } }));
}

const { category } = Astro.params;
const categoryData = questions[category as keyof typeof questions];
if (!categoryData) return Astro.redirect('/categories');

const quizQuestions = categoryData.questions;
const questionsJson = JSON.stringify(quizQuestions);
---

<Layout
  title={`${categoryData.name} Trivia Quiz — 10 Questions | QuizZone`}
  description={`Play the ${categoryData.name} quiz on QuizZone. ${categoryData.description} 10 questions with timer and instant scoring — free!`}
>
  <Header />

  <main style="max-width:700px;margin:0 auto;padding:16px 16px 32px;">

    <!-- INTRO -->
    <div id="intro" class="fade-in">
      <!-- Breadcrumb -->
      <div style="font-size:12px;color:#92733a;margin-bottom:14px;display:flex;align-items:center;gap:4px;flex-wrap:wrap;">
        <a href="/" style="color:#92733a;font-weight:600;">Home</a>
        <span>›</span>
        <a href="/categories" style="color:#92733a;font-weight:600;">Categories</a>
        <span>›</span>
        <span style="color:#5b4220;font-weight:700;">{categoryData.name}</span>
      </div>

      <div style="background:white;border-radius:20px;padding:28px 20px 24px;text-align:center;box-shadow:0 4px 16px rgba(0,0,0,0.1);">
        <div style="font-size:56px;margin-bottom:14px;">{categoryData.icon}</div>
        <h1 style="font-size:24px;font-weight:900;color:#1a1040;margin-bottom:8px;">{categoryData.name} Quiz</h1>
        <p style="font-size:14px;color:#6b7280;max-width:320px;margin:0 auto 24px;line-height:1.6;">{categoryData.description}</p>

        <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:8px;margin-bottom:28px;">
          {[['❓','10 Questions'],['⏱️','30 sec / Q'],['🏆','Score tracking'],['💡','Explanations']].map(([ic,lb]) => (
            <div style="background:#f3f4f6;border-radius:100px;padding:7px 14px;font-size:12px;font-weight:600;color:#374151;display:flex;align-items:center;gap:5px;">
              <span>{ic}</span><span>{lb}</span>
            </div>
          ))}
        </div>

        <button id="start-btn"
          style="width:100%;padding:16px;background:#1a1040;color:white;font-size:16px;font-weight:800;border-radius:100px;border:none;cursor:pointer;transition:all 0.15s;letter-spacing:0.2px;"
          onmouseover="this.style.background='#2d1b69';this.style.transform='translateY(-1px)';"
          onmouseout="this.style.background='#1a1040';this.style.transform='translateY(0)';">
          Start Quiz ▶
        </button>
      </div>
    </div>

    <!-- QUIZ -->
    <div id="quiz" style="display:none;" class="fade-in">
      <div style="background:white;border-radius:20px;padding:20px;box-shadow:0 4px 16px rgba(0,0,0,0.1);">

        <!-- Top: Question counter + Timer -->
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
          <div style="display:flex;align-items:center;gap:7px;font-size:14px;font-weight:700;color:#1a1040;">
            <span id="q-icon" style="font-size:16px;">{categoryData.icon}</span>
            <span>Question <span id="q-num">1</span>/10</span>
          </div>
          <div id="timer-pill" style="background:#1a1040;color:white;font-size:13px;font-weight:800;padding:6px 14px;border-radius:100px;display:flex;align-items:center;gap:5px;">
            ⏱ <span id="timer-val">30</span>s
          </div>
        </div>

        <!-- Progress bar -->
        <div style="height:5px;background:#f3f4f6;border-radius:100px;overflow:hidden;margin-bottom:22px;">
          <div id="prog-bar" style="height:100%;background:#ffe66d;border-radius:100px;transition:width 0.4s ease;width:10%;"></div>
        </div>

        <!-- Question -->
        <p id="q-text" style="font-size:19px;font-weight:800;color:#1a1040;line-height:1.45;text-align:center;min-height:64px;margin-bottom:22px;display:flex;align-items:center;justify-content:center;"></p>

        <!-- Options -->
        <div id="opts" style="display:flex;flex-direction:column;gap:10px;margin-bottom:18px;"></div>

        <!-- Explanation -->
        <div id="explain" style="display:none;background:#f0fdf4;border:2px solid #86efac;border-radius:12px;padding:12px 14px;margin-bottom:14px;">
          <div style="font-size:12px;font-weight:700;color:#166534;margin-bottom:3px;">💡 Explanation</div>
          <p id="explain-txt" style="font-size:13px;color:#15803d;line-height:1.6;"></p>
        </div>

        <!-- Nav buttons -->
        <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;">
          <button id="prev-btn"
            style="flex:1;padding:13px;background:white;border:2px solid #e5e7eb;border-radius:100px;font-size:14px;font-weight:700;color:#6b7280;cursor:pointer;transition:all 0.15s;"
            disabled
            onmouseover="if(!this.disabled){this.style.borderColor='#1a1040';this.style.color='#1a1040';}"
            onmouseout="this.style.borderColor='#e5e7eb';this.style.color='#6b7280';">
            ← Previous
          </button>
          <button id="next-btn"
            style="display:none;flex:1;padding:13px;background:#ffe66d;border:none;border-radius:100px;font-size:14px;font-weight:800;color:#1a1040;cursor:pointer;transition:all 0.15s;"
            onmouseover="this.style.background='#ffd93d';"
            onmouseout="this.style.background='#ffe66d';">
            Next →
          </button>
          <button id="finish-btn"
            style="display:none;flex:1;padding:13px;background:#22c55e;border:none;border-radius:100px;font-size:14px;font-weight:800;color:white;cursor:pointer;transition:all 0.15s;"
            onmouseover="this.style.background='#16a34a';"
            onmouseout="this.style.background='#22c55e';">
            Finish ✓
          </button>
        </div>
      </div>

      <!-- In-content Ad -->
      <div style="background:#ffd93d;border-radius:16px;padding:50px 16px;margin-top:16px;text-align:center;font-size:13px;font-weight:600;color:#92733a;">
        [IN-CONTENT AD]
      </div>
      <div style="background:#ffd93d;border-radius:16px;padding:50px 16px;margin-top:12px;text-align:center;font-size:13px;font-weight:600;color:#92733a;">
        [FOOTER AD]
      </div>
    </div>

    <!-- RESULTS -->
    <div id="results" style="display:none;" class="pop-in">
      <div style="background:white;border-radius:20px;padding:28px 20px;text-align:center;box-shadow:0 4px 16px rgba(0,0,0,0.1);margin-bottom:16px;">
        <div id="res-emoji" style="font-size:60px;margin-bottom:12px;">🏆</div>
        <h2 style="font-size:24px;font-weight:900;color:#1a1040;margin-bottom:6px;">Quiz Complete!</h2>
        <p id="res-msg" style="font-size:14px;color:#6b7280;margin-bottom:24px;"></p>

        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:22px;" id="stats-grid">
          <div style="background:#f5f3ff;border-radius:14px;padding:16px;">
            <div id="res-score" style="font-size:28px;font-weight:900;color:#7c3aed;"></div>
            <div style="font-size:11px;font-weight:700;color:#7c3aed;margin-top:2px;">POINTS</div>
          </div>
          <div style="background:#f0fdf4;border-radius:14px;padding:16px;">
            <div id="res-correct" style="font-size:28px;font-weight:900;color:#16a34a;"></div>
            <div style="font-size:11px;font-weight:700;color:#16a34a;margin-top:2px;">CORRECT</div>
          </div>
          <div style="background:#fef2f2;border-radius:14px;padding:16px;">
            <div id="res-wrong" style="font-size:28px;font-weight:900;color:#dc2626;"></div>
            <div style="font-size:11px;font-weight:700;color:#dc2626;margin-top:2px;">WRONG</div>
          </div>
          <div style="background:#fefce8;border-radius:14px;padding:16px;">
            <div id="res-pct" style="font-size:28px;font-weight:900;color:#ca8a04;"></div>
            <div style="font-size:11px;font-weight:700;color:#ca8a04;margin-top:2px;">ACCURACY</div>
          </div>
        </div>

        <div style="display:flex;flex-direction:column;gap:10px;">
          <button id="again-btn"
            style="width:100%;padding:15px;background:#1a1040;color:white;font-size:15px;font-weight:800;border-radius:100px;border:none;cursor:pointer;transition:background 0.15s;"
            onmouseover="this.style.background='#2d1b69';" onmouseout="this.style.background='#1a1040';">
            🔄 Play Again
          </button>
          <a href="/categories"
            style="width:100%;padding:15px;background:#ffe66d;color:#1a1040;font-size:15px;font-weight:800;border-radius:100px;text-align:center;display:block;transition:background 0.15s;"
            onmouseover="this.style.background='#ffd93d';" onmouseout="this.style.background='#ffe66d';">
            🎯 Try Another Quiz
          </a>
          <button id="share-btn"
            style="width:100%;padding:15px;background:white;border:2px solid #e5e7eb;color:#1a1040;font-size:15px;font-weight:800;border-radius:100px;cursor:pointer;transition:all 0.15s;"
            onmouseover="this.style.borderColor='#1a1040';" onmouseout="this.style.borderColor='#e5e7eb';">
            🔗 Share Score
          </button>
        </div>
      </div>

      <!-- Review -->
      <div style="background:white;border-radius:20px;padding:20px;box-shadow:0 2px 8px rgba(0,0,0,0.08);">
        <h3 style="font-size:17px;font-weight:800;color:#1a1040;margin-bottom:16px;">Answer Review</h3>
        <div id="review" style="display:flex;flex-direction:column;gap:10px;"></div>
      </div>
    </div>

  </main>

  <Footer />
</Layout>

<script define:vars={{ questionsJson, categoryName: categoryData.name }}>
  const QS = JSON.parse(questionsJson);
  const TOTAL = 10;
  const TIME = 30;

  let idx = 0, score = 0, timeLeft = TIME, timerInt = null, startMs = 0;
  let answers = Array(TOTAL).fill(null);

  const introEl   = document.getElementById('intro');
  const quizEl    = document.getElementById('quiz');
  const resEl     = document.getElementById('results');
  const startBtn  = document.getElementById('start-btn');
  const prevBtn   = document.getElementById('prev-btn');
  const nextBtn   = document.getElementById('next-btn');
  const finishBtn = document.getElementById('finish-btn');
  const againBtn  = document.getElementById('again-btn');
  const shareBtn  = document.getElementById('share-btn');
  const qNum      = document.getElementById('q-num');
  const timerVal  = document.getElementById('timer-val');
  const timerPill = document.getElementById('timer-pill');
  const progBar   = document.getElementById('prog-bar');
  const qText     = document.getElementById('q-text');
  const opts      = document.getElementById('opts');
  const explain   = document.getElementById('explain');
  const explainTxt= document.getElementById('explain-txt');
  const review    = document.getElementById('review');

  function show(el) { el.style.display = 'block'; }
  function hide(el) { el.style.display = 'none'; }

  startBtn.addEventListener('click', () => {
    hide(introEl); show(quizEl);
    startMs = Date.now();
    render();
  });

  function render() {
    const q = QS[idx];
    const done = answers[idx] !== null;
    qNum.textContent = idx + 1;
    progBar.style.width = ((idx + 1) / TOTAL * 100) + '%';
    qText.textContent = q.question;

    opts.innerHTML = '';
    q.options.forEach((opt, i) => {
      const btn = document.createElement('button');
      btn.textContent = opt;
      btn.style.cssText = getStyle(i, done, q.correct, answers[idx]);
      if (!done) {
        btn.addEventListener('click', () => pick(i));
        btn.addEventListener('mouseenter', () => { if (answers[idx] === null) btn.style.background = '#2d1b69'; });
        btn.addEventListener('mouseleave', () => { if (answers[idx] === null) btn.style.background = '#1a1040'; });
      }
      opts.appendChild(btn);
    });

    if (done) {
      explainTxt.textContent = q.explanation;
      show(explain);
      stopTimer();
    } else {
      hide(explain);
      startTimer();
    }

    prevBtn.disabled = idx === 0;
    prevBtn.style.opacity = idx === 0 ? '0.4' : '1';
    nextBtn.style.display = (done && idx < TOTAL - 1) ? 'block' : 'none';
    finishBtn.style.display = (done && idx === TOTAL - 1) ? 'block' : 'none';
  }

  function getStyle(i, done, correct, picked) {
    const base = 'width:100%;padding:15px 18px;border-radius:100px;font-size:15px;font-weight:700;border:none;cursor:pointer;transition:background 0.15s;text-align:center;';
    if (!done) return base + 'background:#1a1040;color:white;';
    if (i === correct) return base + 'background:#22c55e;color:white;cursor:default;';
    if (i === picked && i !== correct) return base + 'background:#ef4444;color:white;cursor:default;';
    return base + 'background:#e5e7eb;color:#9ca3af;cursor:default;';
  }

  function pick(i) {
    if (answers[idx] !== null) return;
    stopTimer();
    const q = QS[idx];
    answers[idx] = i;
    if (i === q.correct) score += Math.max(1, timeLeft * 3);
    render();
  }

  function startTimer() {
    stopTimer();
    timeLeft = TIME;
    updateTimer();
    timerInt = setInterval(() => {
      timeLeft--;
      updateTimer();
      if (timeLeft <= 0) { stopTimer(); pick(-1); }
    }, 1000);
  }

  function stopTimer() { clearInterval(timerInt); timerInt = null; }

  function updateTimer() {
    timerVal.textContent = timeLeft;
    timerPill.style.background = timeLeft > 15 ? '#1a1040' : timeLeft > 7 ? '#d97706' : '#ef4444';
  }

  prevBtn.addEventListener('click', () => { if (idx > 0) { stopTimer(); idx--; render(); } });
  nextBtn.addEventListener('click', () => { if (idx < TOTAL - 1) { stopTimer(); idx++; render(); } });
  finishBtn.addEventListener('click', showResults);

  function showResults() {
    stopTimer();
    const elapsed = Math.round((Date.now() - startMs) / 1000);
    const correct = answers.filter((a, i) => a === QS[i].correct).length;
    const pct = Math.round(correct / TOTAL * 100);

    hide(quizEl); show(resEl);

    document.getElementById('res-score').textContent = score;
    document.getElementById('res-correct').textContent = correct;
    document.getElementById('res-wrong').textContent = TOTAL - correct;
    document.getElementById('res-pct').textContent = pct + '%';

    const emoji = pct >= 90 ? '🏆' : pct >= 70 ? '🎉' : pct >= 50 ? '😊' : '💪';
    const msg = pct >= 90 ? 'Outstanding! Perfect score!' : pct >= 70 ? 'Great job! Well done!' : pct >= 50 ? 'Not bad — keep practicing!' : "Don't give up, try again!";
    document.getElementById('res-emoji').textContent = emoji;
    document.getElementById('res-msg').textContent = msg;

    review.innerHTML = '';
    QS.forEach((q, i) => {
      const ok = answers[i] === q.correct;
      const d = document.createElement('div');
      d.style.cssText = `padding:14px;border-radius:12px;border:2px solid ${ok ? '#bbf7d0' : '#fecaca'};background:${ok ? '#f0fdf4' : '#fef2f2'};`;
      d.innerHTML = `<div style="display:flex;gap:10px;"><span style="font-size:16px;flex-shrink:0;">${ok ? '✅' : '❌'}</span><div><p style="font-size:13px;font-weight:700;color:#1a1040;margin-bottom:4px;">${i+1}. ${q.question}</p>${!ok && answers[i] >= 0 ? `<p style="font-size:12px;color:#dc2626;margin-bottom:3px;">Your answer: ${q.options[answers[i]]}</p>` : ''}${!ok ? `<p style="font-size:12px;color:#15803d;margin-bottom:3px;">✓ Correct: ${q.options[q.correct]}</p>` : ''}<p style="font-size:12px;color:#6b7280;line-height:1.5;">${q.explanation}</p></div></div>`;
      review.appendChild(d);
    });
  }

  againBtn.addEventListener('click', () => {
    idx = 0; score = 0; answers = Array(TOTAL).fill(null); startMs = Date.now();
    hide(resEl); show(quizEl); render();
  });

  shareBtn.addEventListener('click', () => {
    const correct = answers.filter((a,i) => a === QS[i].correct).length;
    const pct = Math.round(correct / TOTAL * 100);
    const text = `I scored ${pct}% on the ${categoryName} quiz on QuizZone! 🧠 ${location.href}`;
    if (navigator.share) navigator.share({ title: 'QuizZone', text, url: location.href });
    else navigator.clipboard?.writeText(text).then(() => {
      shareBtn.textContent = '✅ Copied to clipboard!';
      setTimeout(() => { shareBtn.textContent = '🔗 Share Score'; }, 2000);
    });
  });
</script>
