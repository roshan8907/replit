---
import Layout from '@layouts/Layout.astro';
import AdPlaceholder from '@components/AdPlaceholder.astro';
import questions from '@data/questions.json';

export async function getStaticPaths() {
  return Object.keys(questions).map((slug) => ({
    params: { category: slug },
  }));
}

const { category } = Astro.params;
const categoryData = questions[category as keyof typeof questions];

if (!categoryData) {
  return Astro.redirect('/categories');
}

const quizQuestions = categoryData.questions;
const questionsJson = JSON.stringify(quizQuestions);
---

<Layout
  title={`${categoryData.name} Quiz — 10 Questions | QuizZone`}
  description={`Take the ${categoryData.name} trivia quiz on QuizZone. ${categoryData.description} 10 questions, timer included.`}
  canonical={`/quiz/${category}`}
>
  <!-- Structured Data for Quiz -->
  <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Quiz",
      "name": `${categoryData.name} Trivia Quiz`,
      "description": categoryData.description,
      "url": `https://quizzone.replit.app/quiz/${category}`,
      "educationalLevel": "general",
      "numberOfQuestions": quizQuestions.length,
    })}
  </script>

  <div class="min-h-screen bg-gradient-to-br from-gray-50 to-blue-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8 sm:py-12">

      <!-- Quiz Header Info (shown before start) -->
      <div id="quiz-intro" class="text-center mb-8">
        <div class={`w-20 h-20 rounded-2xl bg-gradient-to-br ${categoryData.color} flex items-center justify-center text-4xl mx-auto mb-5 shadow-lg`}>
          {categoryData.icon}
        </div>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-3">{categoryData.name} Quiz</h1>
        <p class="text-gray-500 text-lg mb-6">{categoryData.description}</p>
        <div class="flex flex-wrap justify-center gap-4 text-sm mb-8">
          <div class="flex items-center gap-2 bg-white rounded-xl px-4 py-2 shadow-sm border border-gray-100">
            <span class="text-blue-500">❓</span>
            <span class="font-medium text-gray-700">10 Questions</span>
          </div>
          <div class="flex items-center gap-2 bg-white rounded-xl px-4 py-2 shadow-sm border border-gray-100">
            <span class="text-orange-500">⏱️</span>
            <span class="font-medium text-gray-700">30 sec per question</span>
          </div>
          <div class="flex items-center gap-2 bg-white rounded-xl px-4 py-2 shadow-sm border border-gray-100">
            <span class="text-green-500">🏆</span>
            <span class="font-medium text-gray-700">Score tracking</span>
          </div>
        </div>
        <button
          id="start-btn"
          class="inline-flex items-center gap-2 px-10 py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-2xl shadow-lg hover:shadow-xl transition-all text-lg"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 010 1.972l-11.54 6.347a1.125 1.125 0 01-1.667-.986V5.653z" />
          </svg>
          Start Quiz
        </button>
      </div>

      <!-- Quiz Card (hidden until started) -->
      <div id="quiz-container" class="hidden animate-fade-in">

        <!-- Progress Bar -->
        <div class="mb-6">
          <div class="flex justify-between items-center mb-2">
            <span id="question-counter" class="text-sm font-semibold text-gray-600">Question 1 of 10</span>
            <span id="score-display" class="text-sm font-semibold text-blue-600">Score: 0</span>
          </div>
          <div class="w-full bg-gray-200 rounded-full h-2.5 overflow-hidden">
            <div id="progress-bar" class="bg-blue-600 h-2.5 rounded-full transition-all duration-300" style="width: 10%"></div>
          </div>
        </div>

        <!-- Timer + Question -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <!-- Timer bar -->
          <div class="px-6 pt-5 pb-4 border-b border-gray-50">
            <div class="flex items-center justify-between mb-2">
              <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Time Remaining</span>
              <span id="timer-text" class="text-lg font-bold text-gray-900">30s</span>
            </div>
            <div class="w-full bg-gray-100 rounded-full h-2 overflow-hidden">
              <div id="timer-bar" class="h-2 rounded-full transition-all duration-1000" style="width: 100%; background-color: #22c55e;"></div>
            </div>
          </div>

          <!-- Question -->
          <div class="px-6 py-6">
            <p id="question-text" class="text-xl sm:text-2xl font-bold text-gray-900 leading-snug mb-8"></p>

            <!-- Answer Options -->
            <div id="options-container" class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <!-- Options injected by JS -->
            </div>

            <!-- Explanation (shown after answering) -->
            <div id="explanation-box" class="hidden mt-6 p-4 bg-blue-50 border border-blue-100 rounded-xl">
              <p class="text-sm font-semibold text-blue-800 mb-1">💡 Did you know?</p>
              <p id="explanation-text" class="text-sm text-blue-700 leading-relaxed"></p>
            </div>
          </div>

          <!-- Navigation -->
          <div class="px-6 pb-6 flex justify-between items-center gap-3">
            <button
              id="prev-btn"
              class="px-5 py-2.5 border border-gray-200 hover:border-gray-300 hover:bg-gray-50 text-gray-600 font-semibold rounded-xl transition-colors disabled:opacity-40 disabled:cursor-not-allowed text-sm"
              disabled
            >
              ← Previous
            </button>
            <button
              id="next-btn"
              class="hidden px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl transition-colors text-sm"
            >
              Next →
            </button>
            <button
              id="submit-btn"
              class="hidden px-6 py-2.5 bg-green-600 hover:bg-green-700 text-white font-bold rounded-xl transition-colors text-sm"
            >
              Finish Quiz ✓
            </button>
          </div>
        </div>

        <!-- Ad during quiz -->
        <div class="mt-6">
          <AdPlaceholder type="content" />
        </div>
      </div>

      <!-- Results (hidden until finished) -->
      <div id="results-container" class="hidden animate-fade-in">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 text-center">
          <div id="result-emoji" class="text-6xl mb-4">🎉</div>
          <h2 class="text-3xl font-extrabold text-gray-900 mb-2">Quiz Complete!</h2>
          <p id="result-message" class="text-gray-500 mb-8"></p>

          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
            <div class="bg-blue-50 rounded-xl p-4">
              <div id="result-score" class="text-3xl font-extrabold text-blue-600"></div>
              <div class="text-xs text-gray-500 mt-1">Final Score</div>
            </div>
            <div class="bg-green-50 rounded-xl p-4">
              <div id="result-correct" class="text-3xl font-extrabold text-green-600"></div>
              <div class="text-xs text-gray-500 mt-1">Correct</div>
            </div>
            <div class="bg-red-50 rounded-xl p-4">
              <div id="result-incorrect" class="text-3xl font-extrabold text-red-500"></div>
              <div class="text-xs text-gray-500 mt-1">Incorrect</div>
            </div>
            <div class="bg-orange-50 rounded-xl p-4">
              <div id="result-time" class="text-3xl font-extrabold text-orange-500"></div>
              <div class="text-xs text-gray-500 mt-1">Time Taken</div>
            </div>
          </div>

          <!-- Score percentage bar -->
          <div class="mb-8">
            <div class="flex justify-between text-sm mb-2">
              <span class="text-gray-500">Accuracy</span>
              <span id="result-percent" class="font-bold text-gray-900"></span>
            </div>
            <div class="w-full bg-gray-100 rounded-full h-3 overflow-hidden">
              <div id="result-percent-bar" class="h-3 rounded-full bg-blue-600 transition-all duration-1000" style="width: 0%"></div>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <button
              id="play-again-btn"
              class="px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl transition-colors shadow-md"
            >
              Play Again
            </button>
            <a
              href="/categories"
              class="px-6 py-3 border border-gray-200 hover:bg-gray-50 text-gray-700 font-semibold rounded-xl transition-colors text-center"
            >
              Try Another Category
            </a>
            <button
              id="share-btn"
              class="px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl transition-colors shadow-md"
            >
              Share Score 🔗
            </button>
          </div>
        </div>

        <!-- Answer Review -->
        <div class="mt-8">
          <h3 class="text-xl font-extrabold text-gray-900 mb-4">Answer Review</h3>
          <div id="review-container" class="space-y-4"></div>
        </div>
      </div>

    </div>
  </div>
</Layout>

<script define:vars={{ questionsJson, categoryName: categoryData.name }}>
  const QUESTIONS = JSON.parse(questionsJson);
  const TOTAL = 10;
  const TIME_PER_Q = 30;

  let currentIndex = 0;
  let score = 0;
  let answers = new Array(TOTAL).fill(null);
  let startTime = 0;
  let timer = null;
  let timeLeft = TIME_PER_Q;
  let questionStartTimes = [];
  let totalElapsed = 0;

  const introEl = document.getElementById('quiz-intro');
  const quizEl = document.getElementById('quiz-container');
  const resultsEl = document.getElementById('results-container');
  const startBtn = document.getElementById('start-btn');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const submitBtn = document.getElementById('submit-btn');
  const playAgainBtn = document.getElementById('play-again-btn');
  const shareBtn = document.getElementById('share-btn');
  const timerBar = document.getElementById('timer-bar');
  const timerText = document.getElementById('timer-text');
  const progressBar = document.getElementById('progress-bar');
  const questionCounter = document.getElementById('question-counter');
  const scoreDisplay = document.getElementById('score-display');
  const questionText = document.getElementById('question-text');
  const optionsContainer = document.getElementById('options-container');
  const explanationBox = document.getElementById('explanation-box');
  const explanationText = document.getElementById('explanation-text');
  const reviewContainer = document.getElementById('review-container');

  function startQuiz() {
    introEl.classList.add('hidden');
    quizEl.classList.remove('hidden');
    startTime = Date.now();
    loadQuestion();
  }

  function loadQuestion() {
    const q = QUESTIONS[currentIndex];
    const hasAnswered = answers[currentIndex] !== null;

    questionCounter.textContent = `Question ${currentIndex + 1} of ${TOTAL}`;
    scoreDisplay.textContent = `Score: ${score}`;
    progressBar.style.width = `${((currentIndex + 1) / TOTAL) * 100}%`;
    questionText.textContent = q.question;

    optionsContainer.innerHTML = '';
    q.options.forEach((opt, i) => {
      const btn = document.createElement('button');
      btn.className = getOptionClass(i, hasAnswered, q.correct);
      btn.textContent = `${String.fromCharCode(65 + i)}) ${opt}`;
      btn.dataset.index = i;
      if (!hasAnswered) {
        btn.addEventListener('click', () => selectAnswer(i));
      }
      optionsContainer.appendChild(btn);
    });

    if (hasAnswered) {
      showExplanation();
      clearTimerDisplay();
    } else {
      explanationBox.classList.add('hidden');
      startTimer();
    }

    prevBtn.disabled = currentIndex === 0;
    nextBtn.classList.toggle('hidden', currentIndex === TOTAL - 1 || !hasAnswered);
    submitBtn.classList.toggle('hidden', currentIndex !== TOTAL - 1 || !hasAnswered);
  }

  function getOptionClass(index, hasAnswered, correct) {
    const base = 'w-full text-left px-5 py-4 rounded-xl border-2 font-medium text-sm transition-all duration-200 ';
    if (!hasAnswered) {
      return base + 'border-gray-100 bg-gray-50 hover:border-blue-300 hover:bg-blue-50 text-gray-700 cursor-pointer';
    }
    const userAnswer = answers[currentIndex];
    if (index === correct) return base + 'border-green-400 bg-green-50 text-green-800 cursor-default';
    if (index === userAnswer && index !== correct) return base + 'border-red-400 bg-red-50 text-red-800 cursor-default';
    return base + 'border-gray-100 bg-gray-50 text-gray-400 cursor-default opacity-60';
  }

  function selectAnswer(idx) {
    if (answers[currentIndex] !== null) return;
    clearInterval(timer);

    const q = QUESTIONS[currentIndex];
    answers[currentIndex] = idx;
    if (idx === q.correct) {
      score += Math.max(1, Math.ceil(timeLeft / 3));
    }

    const btns = optionsContainer.querySelectorAll('button');
    btns.forEach((btn, i) => {
      btn.className = getOptionClass(i, true, q.correct);
      btn.replaceWith(btn.cloneNode(true));
    });

    showExplanation();
    clearTimerDisplay();

    nextBtn.classList.toggle('hidden', currentIndex === TOTAL - 1);
    submitBtn.classList.toggle('hidden', currentIndex !== TOTAL - 1);
    scoreDisplay.textContent = `Score: ${score}`;
  }

  function showExplanation() {
    const q = QUESTIONS[currentIndex];
    explanationText.textContent = q.explanation;
    explanationBox.classList.remove('hidden');
  }

  function startTimer() {
    clearInterval(timer);
    timeLeft = TIME_PER_Q;
    updateTimerUI();

    timer = setInterval(() => {
      timeLeft--;
      updateTimerUI();
      if (timeLeft <= 0) {
        clearInterval(timer);
        if (answers[currentIndex] === null) {
          selectAnswer(-1);
        }
      }
    }, 1000);
  }

  function updateTimerUI() {
    timerText.textContent = `${timeLeft}s`;
    const pct = (timeLeft / TIME_PER_Q) * 100;
    timerBar.style.width = `${pct}%`;
    if (pct > 60) timerBar.style.backgroundColor = '#22c55e';
    else if (pct > 30) timerBar.style.backgroundColor = '#f59e0b';
    else timerBar.style.backgroundColor = '#ef4444';
  }

  function clearTimerDisplay() {
    clearInterval(timer);
    timerText.textContent = '—';
    timerBar.style.width = '0%';
  }

  function showResults() {
    clearInterval(timer);
    totalElapsed = Math.round((Date.now() - startTime) / 1000);
    const correctCount = answers.filter((a, i) => a === QUESTIONS[i].correct).length;
    const incorrectCount = TOTAL - correctCount;
    const pct = Math.round((correctCount / TOTAL) * 100);

    quizEl.classList.add('hidden');
    resultsEl.classList.remove('hidden');

    document.getElementById('result-score').textContent = score;
    document.getElementById('result-correct').textContent = correctCount;
    document.getElementById('result-incorrect').textContent = incorrectCount;
    document.getElementById('result-time').textContent = `${totalElapsed}s`;
    document.getElementById('result-percent').textContent = `${pct}%`;

    const emoji = pct >= 90 ? '🏆' : pct >= 70 ? '🎉' : pct >= 50 ? '😊' : '💪';
    const message = pct >= 90 ? 'Outstanding! You nailed it!' : pct >= 70 ? 'Great job! Well done!' : pct >= 50 ? 'Not bad — keep practicing!' : 'Keep going — you\'ll improve!';
    document.getElementById('result-emoji').textContent = emoji;
    document.getElementById('result-message').textContent = message;

    setTimeout(() => {
      document.getElementById('result-percent-bar').style.width = `${pct}%`;
    }, 100);

    // Build review
    reviewContainer.innerHTML = '';
    QUESTIONS.forEach((q, i) => {
      const userAns = answers[i];
      const isCorrect = userAns === q.correct;
      const div = document.createElement('div');
      div.className = `p-5 rounded-xl border-2 ${isCorrect ? 'border-green-200 bg-green-50' : 'border-red-100 bg-red-50'}`;
      div.innerHTML = `
        <div class="flex items-start gap-3">
          <span class="text-xl mt-0.5">${isCorrect ? '✅' : '❌'}</span>
          <div class="flex-1 min-w-0">
            <p class="font-semibold text-gray-900 text-sm leading-snug mb-2">${i + 1}. ${q.question}</p>
            ${!isCorrect ? `<p class="text-xs text-red-600 mb-1">Your answer: ${userAns >= 0 ? q.options[userAns] : 'No answer'}</p>` : ''}
            <p class="text-xs ${isCorrect ? 'text-green-700' : 'text-green-700'} mb-2">Correct: ${q.options[q.correct]}</p>
            <p class="text-xs text-gray-500 leading-relaxed">${q.explanation}</p>
          </div>
        </div>
      `;
      reviewContainer.appendChild(div);
    });
  }

  startBtn.addEventListener('click', startQuiz);

  prevBtn.addEventListener('click', () => {
    if (currentIndex > 0) {
      clearInterval(timer);
      currentIndex--;
      loadQuestion();
    }
  });

  nextBtn.addEventListener('click', () => {
    if (currentIndex < TOTAL - 1) {
      clearInterval(timer);
      currentIndex++;
      loadQuestion();
    }
  });

  submitBtn.addEventListener('click', showResults);

  playAgainBtn.addEventListener('click', () => {
    currentIndex = 0;
    score = 0;
    answers = new Array(TOTAL).fill(null);
    startTime = 0;
    totalElapsed = 0;
    resultsEl.classList.add('hidden');
    quizEl.classList.remove('hidden');
    startTime = Date.now();
    loadQuestion();
  });

  shareBtn.addEventListener('click', () => {
    const correctCount = answers.filter((a, i) => a === QUESTIONS[i].correct).length;
    const pct = Math.round((correctCount / TOTAL) * 100);
    const text = `I scored ${pct}% on the ${categoryName} quiz on QuizZone! Can you beat me? 🧠 Try it at ${window.location.href}`;
    if (navigator.share) {
      navigator.share({ title: 'QuizZone Result', text, url: window.location.href });
    } else if (navigator.clipboard) {
      navigator.clipboard.writeText(text).then(() => {
        shareBtn.textContent = '✅ Copied!';
        setTimeout(() => { shareBtn.textContent = 'Share Score 🔗'; }, 2000);
      });
    }
  });
</script>
