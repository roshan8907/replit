---
import Layout from '@layouts/Layout.astro';
---

<Layout
  title="Page Not Found | QuizZone"
  description="The page you're looking for doesn't exist. Go back to QuizZone and keep playing!"
  noindex={true}
>
  <section class="min-h-[60vh] flex items-center justify-center px-4">
    <div class="text-center max-w-md">
      <div class="text-8xl mb-6">🤔</div>
      <h1 class="text-6xl font-extrabold text-gray-900 mb-4">404</h1>
      <h2 class="text-2xl font-bold text-gray-700 mb-4">Page Not Found</h2>
      <p class="text-gray-500 mb-8 leading-relaxed">
        Oops! The page you're looking for seems to have gone missing. Maybe it moved, or maybe you took a wrong turn.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl transition-colors shadow-md"
        >
          Go Home
        </a>
        <a
          href="/categories"
          class="px-6 py-3 border border-gray-200 hover:bg-gray-50 text-gray-700 font-semibold rounded-xl transition-colors"
        >
          Browse Quizzes
        </a>
      </div>
    </div>
  </section>
</Layout>
