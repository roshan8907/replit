---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import questions from '@data/questions.json';

const categories = Object.entries(questions).map(([slug, cat]) => ({
  slug, name: cat.name, icon: cat.icon, description: cat.description, count: cat.questions.length,
}));

const categoryBg: Record<string, string> = {
  'general-knowledge': 'https://images.unsplash.com/photo-1456513080510-7bf3a84b82f8?w=400&q=80',
  'science-nature':    'https://images.unsplash.com/photo-1532187863486-abf9dbad1b69?w=400&q=80',
  'history':           'https://images.unsplash.com/photo-1461360370896-922624d12aa1?w=400&q=80',
  'geography':         'https://images.unsplash.com/photo-1526778548025-fa2f459cd5c1?w=400&q=80',
  'entertainment':     'https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?w=400&q=80',
  'sports':            'https://images.unsplash.com/photo-1461896836934-ffe607ba8211?w=400&q=80',
  'technology':        'https://images.unsplash.com/photo-1518770660439-4636190af475?w=400&q=80',
  'food-drink':        'https://images.unsplash.com/photo-1476718406336-bb5a9690ee2a?w=400&q=80',
  'free-iq-test':      '/iq-test.png',
  'personality-quiz':  '/personality-quiz.png',
  'memory-challenge':  '/memory-challenge.png',
  'speed-trivia':      '/speed-trivia.png',
};

const badgeColors: Record<string, string> = {
  'general-knowledge':'#f97316','science-nature':'#10b981','history':'#f59e0b',
  'geography':'#06b6d4','entertainment':'#a855f7','sports':'#ef4444',
  'technology':'#3b82f6','food-drink':'#ec4899',
};
---

<Layout
  title="All Quiz Categories | QuizZone"
  description="Explore all 8 free trivia quiz categories on QuizZone — General Knowledge, Science, History, Geography, Sports, Technology, Food & Drink, Entertainment. 10 questions each, timed, free forever."
  canonical="/categories"
>
  <Header />

  <main style="max-width:700px;margin:0 auto;padding:16px 16px 32px;">

    <!-- Back to home -->
    <a href="/" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:700;color:#92733a;margin-bottom:14px;padding:8px 14px;background:rgba(255,255,255,0.6);border-radius:100px;">
      ← Home
    </a>

    <!-- Hero -->
    <div style="background:#1a1040;border-radius:20px;padding:28px 20px;text-align:center;margin-bottom:16px;">
      <h1 style="font-size:26px;font-weight:900;color:white;line-height:1.2;margin-bottom:8px;">All Quiz Categories</h1>
      <p style="font-size:13px;color:rgba(255,255,255,0.6);">{categories.length} categories · 10 questions each · Timed · Free forever</p>
    </div>

    <!-- Ad -->
    <div style="border-radius:16px;margin-bottom:16px;text-align:center;overflow:hidden;">
      <script is:inline>
        atOptions = {
          'key' : 'e3f702bf5c1581f67addbb9a2114c289',
          'format' : 'iframe',
          'height' : 90,
          'width' : 728,
          'params' : {}
        };
      </script>
      <script is:inline src="https://anniversaryvacuumambassador.com/e3f702bf5c1581f67addbb9a2114c289/invoke.js"></script>
    </div>

    <!-- IMAGE card grid -->
    <div style="font-size:12px;font-weight:700;color:#92733a;text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;">Choose your challenge</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px;" class="cat-img-grid">
      {categories.map((cat) => (
        <a href={`/quiz/${cat.slug}`}
          style="display:block;border-radius:16px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.15);transition:all 0.2s;aspect-ratio:1/1;position:relative;"
          onmouseover="this.style.transform='scale(1.03)';this.style.boxShadow='0 10px 24px rgba(0,0,0,0.3)';"
          onmouseout="this.style.transform='scale(1)';this.style.boxShadow='0 2px 8px rgba(0,0,0,0.15)';">
          <img
            src={categoryBg[cat.slug]}
            alt={`${cat.name} trivia quiz`}
            loading="lazy"
            style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;"/>
          <div style="position:absolute;inset:0;background:linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.65) 100%);"></div>
          <div style="position:absolute;top:9px;left:9px;font-size:9px;font-weight:700;color:rgba(255,255,255,0.7);text-transform:uppercase;letter-spacing:0.5px;line-height:1.3;">{cat.name}</div>
          <div style={`position:absolute;top:7px;right:7px;width:30px;height:30px;border-radius:50%;background:${badgeColors[cat.slug]||'#f97316'};display:flex;align-items:center;justify-content:center;font-size:14px;box-shadow:0 2px 6px rgba(0,0,0,0.3);`}>{cat.icon}</div>
          <div style="position:absolute;bottom:0;left:0;right:0;padding:32px 12px 12px;background:linear-gradient(to top,rgba(0,0,0,0.85),transparent);">
            <div style="font-size:17px;font-weight:900;color:white;line-height:1.2;text-shadow:0 1px 4px rgba(0,0,0,0.5);">{cat.name}</div>
          </div>
        </a>
      ))}
    </div>

    <!-- White card style too -->
    <div style="font-size:12px;font-weight:700;color:#92733a;text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;">All categories</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px;" class="cat-white-grid">
      {categories.map((cat) => (
        <a href={`/quiz/${cat.slug}`}
          style="display:block;background:white;border-radius:16px;padding:20px 14px 16px;box-shadow:0 2px 8px rgba(0,0,0,0.08);transition:all 0.18s;text-decoration:none;"
          onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 8px 20px rgba(0,0,0,0.14)';"
          onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 2px 8px rgba(0,0,0,0.08)';">
          <div style="font-size:40px;margin-bottom:10px;">{cat.icon}</div>
          <div style="font-size:14px;font-weight:800;color:#1a1040;margin-bottom:4px;">{cat.name}</div>
          <div style="font-size:11px;color:#9ca3af;line-height:1.5;margin-bottom:10px;">{cat.description}</div>
          <div style="display:flex;align-items:center;justify-content:space-between;">
            <span style="font-size:11px;font-weight:600;color:#9ca3af;">{cat.count} Questions</span>
            <span style="font-size:12px;font-weight:800;color:#7c3aed;">Play →</span>
          </div>
        </a>
      ))}
    </div>

    <!-- Why play -->
    <div style="background:#1a1040;border-radius:20px;padding:24px 20px;text-align:center;">
      <h2 style="font-size:18px;font-weight:900;color:white;margin-bottom:16px;">Why play on QuizZone?</h2>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;">
        {[['🆓','Free','No sign-up needed'],['⚡','Instant','Results right away'],['📱','Any device','Phone, tablet, desktop']].map(([ic,t,d]) => (
          <div style="background:rgba(255,255,255,0.1);border-radius:12px;padding:14px 10px;">
            <div style="font-size:24px;margin-bottom:6px;">{ic}</div>
            <div style="font-size:13px;font-weight:800;color:white;margin-bottom:3px;">{t}</div>
            <div style="font-size:11px;color:rgba(255,255,255,0.6);line-height:1.4;">{d}</div>
          </div>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  @media (min-width:540px){
    .cat-img-grid,.cat-white-grid{ grid-template-columns:repeat(3,1fr) !important; }
  }
  @media (min-width:700px){
    .cat-img-grid,.cat-white-grid{ grid-template-columns:repeat(4,1fr) !important; }
  }
</style>
