---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import questions from '@data/questions.json';

const categories = Object.entries(questions).map(([slug, cat]) => ({
  slug, name: cat.name, icon: cat.icon, description: cat.description, count: cat.questions.length,
}));

const gradients: Record<string, string> = {
  'general-knowledge': 'linear-gradient(135deg,#1a1040 0%,#2d1b69 100%)',
  'science-nature':    'linear-gradient(135deg,#064e3b 0%,#065f46 100%)',
  'history':           'linear-gradient(135deg,#78350f 0%,#92400e 100%)',
  'geography':         'linear-gradient(135deg,#0c4a6e 0%,#075985 100%)',
  'entertainment':     'linear-gradient(135deg,#4c1d95 0%,#6d28d9 100%)',
  'sports':            'linear-gradient(135deg,#7c2d12 0%,#9a3412 100%)',
  'technology':        'linear-gradient(135deg,#1e3a5f 0%,#1e40af 100%)',
  'food-drink':        'linear-gradient(135deg,#7f1d1d 0%,#991b1b 100%)',
};

const badgeColors: Record<string, string> = {
  'general-knowledge':'#f97316','science-nature':'#10b981','history':'#f59e0b',
  'geography':'#06b6d4','entertainment':'#a855f7','sports':'#ef4444',
  'technology':'#3b82f6','food-drink':'#ec4899',
};
---

<Layout
  title="All Quiz Categories | QuizZone"
  description="Explore all 8 free trivia quiz categories on QuizZone — General Knowledge, Science, History, Geography, Sports, Technology, Food & Drink, Entertainment. 10 questions each, timed, free forever."
  canonical="/categories"
>
  <Header />

  <main style="max-width:700px;margin:0 auto;padding:16px 16px 32px;">

    <!-- Back to home -->
    <a href="/" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:700;color:#92733a;margin-bottom:14px;padding:8px 14px;background:rgba(255,255,255,0.6);border-radius:100px;backdrop-filter:blur(4px);">
      ← Home
    </a>

    <!-- Hero card -->
    <div style="background:#1a1040;border-radius:20px;padding:28px 20px;text-align:center;margin-bottom:16px;">
      <h1 style="font-size:26px;font-weight:900;color:white;line-height:1.2;margin-bottom:8px;">All Quiz Categories</h1>
      <p style="font-size:13px;color:rgba(255,255,255,0.6);">{categories.length} categories · 10 questions each · Timed · Free forever</p>
    </div>

    <!-- Ad -->
    <div style="background:#ffd93d;border-radius:16px;padding:22px 16px;text-align:center;font-size:13px;font-weight:600;color:#92733a;margin-bottom:16px;">
      [Advertisement — Top Banner 728×90]
    </div>

    <!-- Category cards — white card style with big icon -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;" class="cat-grid-white">
      {categories.map((cat) => (
        <a href={`/quiz/${cat.slug}`}
          style="display:block;background:white;border-radius:16px;padding:20px 14px 16px;box-shadow:0 2px 8px rgba(0,0,0,0.08);transition:all 0.18s;text-decoration:none;"
          onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 8px 20px rgba(0,0,0,0.14)';"
          onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 2px 8px rgba(0,0,0,0.08)';">
          <div style="font-size:44px;margin-bottom:12px;text-align:center;">{cat.icon}</div>
          <div style="font-size:14px;font-weight:800;color:#1a1040;margin-bottom:4px;">{cat.name}</div>
          <div style="font-size:11px;color:#9ca3af;line-height:1.5;margin-bottom:10px;">{cat.description}</div>
          <div style="display:flex;align-items:center;justify-content:space-between;">
            <span style="font-size:11px;font-weight:600;color:#9ca3af;">{cat.count} Questions</span>
            <span style="font-size:12px;font-weight:800;color:#7c3aed;">Play →</span>
          </div>
        </a>
      ))}
    </div>

    <!-- Dark grid style (image cards) -->
    <div style="font-size:12px;font-weight:700;color:#92733a;text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;">Browse by card</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px;" class="cat-grid-dark">
      {categories.map((cat) => (
        <a href={`/quiz/${cat.slug}`}
          style={`display:block;border-radius:16px;overflow:hidden;background:${gradients[cat.slug]||'linear-gradient(135deg,#1a1040,#2d1b69)'};box-shadow:0 2px 8px rgba(0,0,0,0.15);transition:all 0.18s;aspect-ratio:1/1;position:relative;`}
          onmouseover="this.style.transform='scale(1.02)';this.style.boxShadow='0 8px 20px rgba(0,0,0,0.25)';"
          onmouseout="this.style.transform='scale(1)';this.style.boxShadow='0 2px 8px rgba(0,0,0,0.15)';">
          <div style="position:absolute;top:9px;left:9px;font-size:9px;font-weight:700;color:rgba(255,255,255,0.55);text-transform:uppercase;letter-spacing:0.5px;line-height:1.3;">{cat.name.toUpperCase()}</div>
          <div style={`position:absolute;top:7px;right:7px;width:30px;height:30px;border-radius:50%;background:${badgeColors[cat.slug]||'#f97316'};display:flex;align-items:center;justify-content:center;font-size:14px;`}>{cat.icon}</div>
          <div style="position:absolute;bottom:0;left:0;right:0;padding:28px 12px 12px;background:linear-gradient(to top,rgba(0,0,0,0.7),transparent);">
            <div style="font-size:16px;font-weight:900;color:white;line-height:1.2;">{cat.name}</div>
          </div>
        </a>
      ))}
    </div>

    <!-- Why play -->
    <div style="background:#1a1040;border-radius:20px;padding:24px 20px;text-align:center;margin-bottom:16px;">
      <h2 style="font-size:18px;font-weight:900;color:white;margin-bottom:16px;">Why play on QuizZone?</h2>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;">
        {[['🆓','Free','No sign-up needed'],['⚡','Instant','See results right away'],['📱','Any device','Phone, tablet, desktop']].map(([ic,t,d]) => (
          <div style="background:rgba(255,255,255,0.1);border-radius:12px;padding:14px 10px;">
            <div style="font-size:24px;margin-bottom:6px;">{ic}</div>
            <div style="font-size:13px;font-weight:800;color:white;margin-bottom:3px;">{t}</div>
            <div style="font-size:11px;color:rgba(255,255,255,0.6);line-height:1.4;">{d}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Ad bottom -->
    <div style="background:#ffd93d;border-radius:16px;padding:30px 16px;text-align:center;font-size:13px;font-weight:600;color:#92733a;">
      [Advertisement — 728×90]
    </div>

  </main>

  <Footer />
</Layout>

<style>
  @media (min-width:540px){
    .cat-grid-white,.cat-grid-dark{ grid-template-columns:repeat(3,1fr) !important; }
  }
  @media (min-width:700px){
    .cat-grid-white,.cat-grid-dark{ grid-template-columns:repeat(4,1fr) !important; }
  }
</style>
