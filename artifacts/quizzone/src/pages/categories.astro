---
import Layout from '@layouts/Layout.astro';
import CategoryCard from '@components/CategoryCard.astro';
import AdPlaceholder from '@components/AdPlaceholder.astro';
import questions from '@data/questions.json';

const categories = Object.entries(questions).map(([slug, cat]) => ({
  slug,
  name: cat.name,
  icon: cat.icon,
  color: cat.color,
  description: cat.description,
  quizCount: cat.quizCount,
  questionCount: cat.questions.length,
}));
---

<Layout
  title="All Quiz Categories | QuizZone"
  description="Explore all trivia quiz categories on QuizZone — general knowledge, science, history, geography, sports, technology, food, and entertainment."
  canonical="/categories"
>
  <!-- Page Header -->
  <section class="bg-gradient-to-br from-gray-50 to-blue-50 border-b border-gray-100" aria-label="Page header">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 mb-4">All Categories</h1>
      <p class="text-lg text-gray-500 max-w-xl mx-auto">
        Choose from {categories.length} trivia categories. Each quiz has 10 questions and a timer. Good luck!
      </p>
    </div>
  </section>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <!-- Top Banner Ad -->
    <AdPlaceholder type="banner" class="mb-10" />

    <!-- Category Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      {categories.map((cat) => (
        <CategoryCard {...cat} />
      ))}
    </div>

    <!-- In-Content Ad -->
    <div class="flex justify-center my-14">
      <AdPlaceholder type="content" />
    </div>

    <!-- Stats Strip -->
    <section class="bg-blue-600 rounded-2xl p-8 sm:p-12 text-white text-center mt-6" aria-label="Stats">
      <h2 class="text-2xl sm:text-3xl font-extrabold mb-8">Why Play on QuizZone?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {[
          { icon: '🆓', label: '100% Free', desc: 'All quizzes are completely free, forever.' },
          { icon: '⚡', label: 'Instant Results', desc: 'See your score immediately after each quiz.' },
          { icon: '📱', label: 'Mobile Friendly', desc: 'Play on any device — phone, tablet, or desktop.' },
        ].map((item) => (
          <div class="bg-white/10 rounded-xl p-6">
            <div class="text-4xl mb-3">{item.icon}</div>
            <div class="font-bold text-lg mb-1">{item.label}</div>
            <div class="text-blue-200 text-sm">{item.desc}</div>
          </div>
        ))}
      </div>
    </section>
  </main>
</Layout>
