---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

const posts = [
  { slug:'brain-teasers-that-trick-you', title:'Brain Teasers That Trick Even Smart People', excerpt:'These brain teasers have stumped millions online. Can you solve them all?', date:'June 12, 2026', category:'Brain Teasers', readTime:'2 min', emoji:'🧠' },
  { slug:'signs-of-high-intelligence', title:'7 Signs You Have Higher Intelligence Than You Think', excerpt:'Scientists say these 7 traits are linked to high intelligence. Do you have them?', date:'June 10, 2026', category:'Psychology', readTime:'2 min', emoji:'🔬' },
  { slug:'riddles-only-geniuses-solve', title:'5 Riddles Only Geniuses Can Solve', excerpt:'These 5 riddles have stumped 90% of people online. Can you crack them?', date:'June 8, 2026', category:'Riddles', readTime:'2 min', emoji:'💡' },
  { slug:'what-your-iq-score-means', title:'What Your IQ Score Actually Means', excerpt:'Ever wondered what IQ scores really mean? Learn the scale and where you stand.', date:'June 5, 2026', category:'IQ Facts', readTime:'2 min', emoji:'📊' },
  { slug:'logic-puzzles-for-adults', title:'Logic Puzzles That Will Melt Your Brain', excerpt:'These logic puzzles for adults are harder than they look. Sharpen your mind!', date:'June 3, 2026', category:'Logic', readTime:'2 min', emoji:'⚡' },
  { slug:'hardest-math-problem-online', title:'The Hardest Math Problem on the Internet Right Now', excerpt:'This math problem went viral because almost nobody gets it right.', date:'May 30, 2026', category:'Math', readTime:'2 min', emoji:'🧮' },
  { slug:'why-smart-people-fail-quizzes', title:'Why Smart People Fail Simple Quizzes', excerpt:"It's a strange paradox — intelligent people often overthink easy questions.", date:'May 25, 2026', category:'Psychology', readTime:'2 min', emoji:'🤔' },
  { slug:'facts-that-make-you-smarter', title:'10 Quick Facts That Will Make You Sound Smarter', excerpt:'Impress your friends with these 10 surprising facts about the world.', date:'May 18, 2026', category:'Fun Facts', readTime:'2 min', emoji:'🎓' },
  { slug:'6th-grade-quiz-for-adults', title:'Can You Pass This 6th Grade Quiz as an Adult?', excerpt:'Most adults can\'t pass a basic 6th grade quiz. Can you?', date:'May 12, 2026', category:'Challenge', readTime:'2 min', emoji:'📚' },
  { slug:'train-your-brain-like-a-champion', title:'How to Train Your Brain Like a Memory Champion', excerpt:'Memory champions use specific techniques to boost brainpower. Learn their secrets.', date:'May 5, 2026', category:'Brain Training', readTime:'2 min', emoji:'🏆' },
  { slug:'best-general-knowledge-questions', title:'The Best General Knowledge Quiz Questions for 2026', excerpt:"We've compiled the ultimate list that's perfect for quiz nights, school competitions, or solo practice.", date:'June 1, 2026', category:'General Knowledge', readTime:'5 min', emoji:'🧩' },
  { slug:'top-geography-quiz-questions', title:'Top 20 Geography Quiz Questions You Must Try', excerpt:'Test your geography knowledge with handpicked questions covering capitals, landmarks, oceans, and mountains.', date:'May 20, 2026', category:'Geography', readTime:'4 min', emoji:'🌍' },
  { slug:'science-quiz-for-students', title:'Science Quiz Questions Every Student Should Know', excerpt:'From biology and chemistry to physics — these science questions cover the fundamentals every student should master.', date:'May 8, 2026', category:'Science', readTime:'6 min', emoji:'🔭' },
  { slug:'history-trivia-questions', title:'25 History Trivia Questions That Will Test Your Knowledge', excerpt:'Dive into ancient civilizations, world wars, and great explorers with these carefully crafted trivia questions.', date:'April 25, 2026', category:'History', readTime:'5 min', emoji:'🏛️' },
  { slug:'sports-trivia-facts', title:'Amazing Sports Trivia Facts and Questions', excerpt:"Whether you're a sports fanatic or a casual fan, these questions will put your knowledge to the test.", date:'April 10, 2026', category:'Sports', readTime:'4 min', emoji:'⚽' },
  { slug:'food-and-drink-trivia', title:'Food & Drink Trivia: Questions from Around the World', excerpt:'From obscure ingredients to famous dishes, these food and drink trivia questions will challenge even seasoned foodies.', date:'March 28, 2026', category:'Food & Drink', readTime:'5 min', emoji:'🍕' },
];

const catColors: Record<string,string> = {
  'Brain Teasers':'#7c3aed','Psychology':'#059669','Riddles':'#dc2626',
  'IQ Facts':'#d97706','Logic':'#0891b2','Math':'#db2777',
  'Fun Facts':'#2563eb','Challenge':'#ea580c','Brain Training':'#16a34a',
  'General Knowledge':'#7c3aed','Geography':'#0891b2','Science':'#059669',
  'History':'#d97706','Sports':'#dc2626','Food & Drink':'#db2777',
};
---

<Layout
  title="Trivia Quiz Blog — Tips, Questions & Guides | QuizZone"
  description="Explore the QuizZone blog for trivia questions, quiz guides, and fascinating facts across science, history, geography, sports, food, and more."
  canonical="/blog"
>
  <Header />

  <main style="max-width:700px;margin:0 auto;padding:16px 16px 32px;">

    <!-- Back button -->
    <a href="/" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:700;color:#92733a;margin-bottom:14px;padding:8px 14px;background:rgba(255,255,255,0.6);border-radius:100px;">
      ← Home
    </a>

    <!-- Hero -->
    <div style="background:#1a1040;border-radius:20px;padding:28px 20px;text-align:center;margin-bottom:16px;">
      <div style="font-size:44px;margin-bottom:10px;">📝</div>
      <h1 style="font-size:24px;font-weight:900;color:white;margin-bottom:6px;">Trivia Blog</h1>
      <p style="font-size:13px;color:rgba(255,255,255,0.6);max-width:300px;margin:0 auto;">Quiz guides, trivia questions, and fascinating facts to keep your brain sharp.</p>
    </div>

    <!-- Featured post -->
    <a href={`/blog/${posts[0].slug}`}
      style="display:block;background:white;border-radius:20px;overflow:hidden;box-shadow:0 4px 16px rgba(0,0,0,0.1);margin-bottom:16px;transition:all 0.18s;text-decoration:none;"
      onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 12px 28px rgba(0,0,0,0.15)';"
      onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 4px 16px rgba(0,0,0,0.1)';">
      <div style="background:linear-gradient(135deg,#1a1040,#4c1d95);height:130px;display:flex;align-items:center;justify-content:center;font-size:64px;position:relative;">
        {posts[0].emoji}
        <span style="position:absolute;top:10px;left:10px;background:#ffe66d;color:#1a1040;font-size:10px;font-weight:800;padding:4px 10px;border-radius:100px;">✨ Featured</span>
      </div>
      <div style="padding:18px 20px 20px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
          <span style={`font-size:11px;font-weight:700;padding:3px 10px;border-radius:100px;background:${catColors[posts[0].category]||'#7c3aed'}20;color:${catColors[posts[0].category]||'#7c3aed'};`}>{posts[0].category}</span>
          <span style="font-size:11px;color:#9ca3af;">{posts[0].readTime} read</span>
        </div>
        <h2 style="font-size:16px;font-weight:800;color:#1a1040;line-height:1.4;margin-bottom:8px;">{posts[0].title}</h2>
        <p style="font-size:13px;color:#6b7280;line-height:1.6;margin-bottom:10px;">{posts[0].excerpt}</p>
        <div style="font-size:12px;color:#9ca3af;">{posts[0].date}</div>
      </div>
    </a>

    <!-- Post grid -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;" class="blog-grid">
      {posts.slice(1).map((post) => (
        <a href={`/blog/${post.slug}`}
          style="display:block;background:white;border-radius:16px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.08);transition:all 0.18s;text-decoration:none;"
          onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 8px 20px rgba(0,0,0,0.13)';"
          onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 2px 8px rgba(0,0,0,0.08)';">
          <div style="background:linear-gradient(135deg,#1a1040,#2d1b69);height:90px;display:flex;align-items:center;justify-content:center;font-size:44px;">
            {post.emoji}
          </div>
          <div style="padding:12px 14px 14px;">
            <span style={`font-size:10px;font-weight:700;padding:2px 8px;border-radius:100px;background:${catColors[post.category]||'#7c3aed'}20;color:${catColors[post.category]||'#7c3aed'};display:inline-block;margin-bottom:6px;`}>{post.category}</span>
            <h2 style="font-size:13px;font-weight:800;color:#1a1040;line-height:1.4;margin-bottom:6px;">{post.title}</h2>
            <div style="font-size:11px;color:#9ca3af;">{post.date} · {post.readTime}</div>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div style="background:#1a1040;border-radius:20px;padding:24px 20px;text-align:center;">
      <h2 style="font-size:17px;font-weight:900;color:white;margin-bottom:8px;">Ready to test your knowledge?</h2>
      <p style="font-size:13px;color:rgba(255,255,255,0.6);margin-bottom:16px;">Jump into a quiz now — it's free and no sign-up needed.</p>
      <a href="/categories"
        style="display:inline-block;padding:14px 28px;background:#ffe66d;color:#1a1040;font-size:14px;font-weight:800;border-radius:100px;transition:background 0.15s;"
        onmouseover="this.style.background='#ffd93d';" onmouseout="this.style.background='#ffe66d';">
        🎯 Browse Quizzes
      </a>
    </div>

  </main>

  <Footer />
</Layout>

<style>
  @media (min-width:540px){
    .blog-grid{ grid-template-columns:repeat(3,1fr) !important; }
  }
</style>
