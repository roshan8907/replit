---
import Layout from '@layouts/Layout.astro';
---
<Layout title="Food & Drink Trivia Questions | QuizZone Blog" description="Food and drink trivia questions from around the world — test your culinary knowledge with these fun questions!" canonical="/blog/food-and-drink-trivia">
  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-sm text-gray-400 mb-8 flex items-center gap-2">
      <a href="/" class="hover:text-blue-600">Home</a><span>›</span><a href="/blog" class="hover:text-blue-600">Blog</a><span>›</span><span class="text-gray-600">Food & Drink Trivia</span>
    </nav>
    <article>
      <header class="mb-10">
        <div class="flex items-center gap-2 mb-4">
          <span class="bg-orange-100 text-orange-700 text-xs font-semibold px-3 py-1 rounded-full">Food & Drink</span>
          <span class="text-xs text-gray-400">March 28, 2024 · 5 min read</span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-4 leading-tight">Food & Drink Trivia: Questions from Around the World</h1>
        <p class="text-lg text-gray-500 leading-relaxed">From sushi to marzipan, these food and drink trivia questions will take your taste buds on a global adventure.</p>
      </header>
      <div class="space-y-4 mb-8">
        {[
          { q: 'Which country is the origin of sushi?', a: 'Japan' },
          { q: 'What is the main ingredient in guacamole?', a: 'Avocado' },
          { q: 'Which cheese is used in a traditional Greek salad?', a: 'Feta' },
          { q: 'What is sake made from?', a: 'Rice' },
          { q: 'Which country invented croissants?', a: 'Austria (popularized in France)' },
          { q: 'What does the Scoville scale measure?', a: 'The heat (spiciness) of chili peppers' },
          { q: 'What nut is used to make marzipan?', a: 'Almonds' },
          { q: 'What type of pasta is tube-shaped?', a: 'Penne' },
        ].map((item, i) => (
          <div class="bg-gray-50 border border-gray-100 rounded-xl p-5">
            <p class="font-semibold text-gray-900 mb-2"><span class="text-orange-600">Q{i + 1}.</span> {item.q}</p>
            <p class="text-sm text-green-700 font-medium">✅ {item.a}</p>
          </div>
        ))}
      </div>
      <div class="bg-orange-50 border border-orange-100 rounded-2xl p-6 text-center">
        <h3 class="text-xl font-bold text-gray-900 mb-2">Play the Food & Drink Quiz!</h3>
        <a href="/quiz/food-drink" class="inline-flex items-center gap-2 px-6 py-3 bg-orange-600 hover:bg-orange-700 text-white font-bold rounded-xl transition-colors shadow-md">Play Now →</a>
      </div>
    </article>
  </main>
</Layout>
