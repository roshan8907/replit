---
const year = new Date().getFullYear();
const navCards = [
  { href: '/', label: 'Home', emoji: '🏠' },
  { href: '/categories', label: 'Categories', emoji: '🗂️' },
  { href: '/blog', label: 'Blog', emoji: '📝' },
  { href: '/contact', label: 'Contact', emoji: '✉️' },
];
---
<footer style="background:#ffe66d;padding:24px 16px 32px;">
  <div style="max-width:700px;margin:0 auto;">

    <!-- Nav grid 2x2 -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:24px;">
      {navCards.map((n) => (
        <a href={n.href} style="background:white;border-radius:16px;padding:20px 16px;display:flex;flex-direction:column;align-items:center;gap:10px;box-shadow:0 2px 8px rgba(0,0,0,0.08);transition:transform 0.15s,box-shadow 0.15s;font-size:14px;font-weight:700;color:#1a1040;"
          onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 6px 16px rgba(0,0,0,0.12)';"
          onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 2px 8px rgba(0,0,0,0.08)';">
          <span style="font-size:36px;">{n.emoji}</span>
          <span>{n.label}</span>
        </a>
      ))}
    </div>

    <!-- Brand -->
    <div style="background:white;border-radius:16px;padding:20px;margin-bottom:16px;">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
        <div style="width:32px;height:32px;background:linear-gradient(135deg,#a855f7,#6c35d3);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;">❓</div>
        <span style="font-size:18px;font-weight:900;color:#1a1040;">Quiz<span style="color:#7c3aed;">Zone</span></span>
      </div>
      <p style="font-size:13px;color:#6b7280;line-height:1.6;">Free online trivia quizzes for curious minds. Play, learn, and challenge your friends.</p>
    </div>

    <!-- Links -->
    <div style="background:white;border-radius:16px;padding:20px;margin-bottom:16px;display:grid;grid-template-columns:1fr 1fr;gap:20px;">
      <div>
        <div style="font-size:13px;font-weight:800;color:#1a1040;margin-bottom:10px;">Explore</div>
        {[['All Categories','/categories'],['Blog','/blog'],['About','/about'],['Contact','/contact']].map(([l,h]) => (
          <a href={h} style="display:block;font-size:13px;color:#6b7280;padding:4px 0;">{l}</a>
        ))}
      </div>
      <div>
        <div style="font-size:13px;font-weight:800;color:#1a1040;margin-bottom:10px;">Legal</div>
        {[['Privacy Policy','/privacy-policy'],['Terms of Service','/terms']].map(([l,h]) => (
          <a href={h} style="display:block;font-size:13px;color:#6b7280;padding:4px 0;">{l}</a>
        ))}
      </div>
    </div>

    <p style="text-align:center;font-size:12px;color:#92733a;padding-top:8px;">&copy; {year} QuizZone. All rights reserved.</p>
  </div>
</footer>
