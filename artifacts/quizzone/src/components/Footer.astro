---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-300 mt-16">
  <!-- Ad Placeholder -->
  <div class="border-b border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="bg-gray-800 border border-dashed border-gray-600 rounded-lg p-4 text-center text-gray-500 text-sm">
        [Advertisement Space — Footer Ad]
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <div class="w-9 h-9 bg-gradient-to-br from-blue-500 to-blue-700 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <span class="text-xl font-bold text-white">Quiz<span class="text-blue-400">Zone</span></span>
        </a>
        <p class="text-sm text-gray-400 leading-relaxed">
          Free online trivia quizzes for everyone. Test your knowledge, challenge friends, and learn something new every day.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-semibold mb-4">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-blue-400 transition-colors">Home</a></li>
          <li><a href="/categories" class="hover:text-blue-400 transition-colors">All Categories</a></li>
          <li><a href="/blog" class="hover:text-blue-400 transition-colors">Blog</a></li>
          <li><a href="/about" class="hover:text-blue-400 transition-colors">About Us</a></li>
          <li><a href="/contact" class="hover:text-blue-400 transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Categories -->
      <div>
        <h3 class="text-white font-semibold mb-4">Popular Quizzes</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/quiz/general-knowledge" class="hover:text-blue-400 transition-colors">General Knowledge</a></li>
          <li><a href="/quiz/science-nature" class="hover:text-blue-400 transition-colors">Science & Nature</a></li>
          <li><a href="/quiz/history" class="hover:text-blue-400 transition-colors">History</a></li>
          <li><a href="/quiz/geography" class="hover:text-blue-400 transition-colors">Geography</a></li>
          <li><a href="/quiz/sports" class="hover:text-blue-400 transition-colors">Sports</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-white font-semibold mb-4">Legal</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/privacy-policy" class="hover:text-blue-400 transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-blue-400 transition-colors">Terms of Service</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-500">
      <p>&copy; {currentYear} QuizZone. All rights reserved.</p>
      <p>Made with ❤️ for curious minds everywhere.</p>
    </div>
  </div>
</footer>
