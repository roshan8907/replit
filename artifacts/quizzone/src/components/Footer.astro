---
const year = new Date().getFullYear();
---
<footer style="background:#111827;color:#9ca3af;margin-top:48px;">
  <div style="max-width:1200px;margin:0 auto;padding:48px 16px 24px;">
    <div style="display:grid;grid-template-columns:1fr;gap:32px;margin-bottom:40px;">

      <!-- Brand -->
      <div>
        <a href="/" style="display:inline-flex;align-items:center;gap:10px;margin-bottom:12px;">
          <div style="width:34px;height:34px;background:linear-gradient(135deg,#a855f7,#6c35d3);border-radius:8px;display:flex;align-items:center;justify-content:center;">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <span style="font-size:20px;font-weight:800;color:white;">Quiz<span style="color:#c084fc;">Zone</span></span>
        </a>
        <p style="font-size:14px;line-height:1.7;max-width:280px;">Free online trivia quizzes for everyone. Challenge yourself daily across dozens of topics.</p>
      </div>

      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:32px;">
        <div>
          <h3 style="color:white;font-size:14px;font-weight:700;margin-bottom:14px;text-transform:uppercase;letter-spacing:0.5px;">Quizzes</h3>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:10px;font-size:14px;">
            {[['General Knowledge','/quiz/general-knowledge'],['Science','/quiz/science-nature'],['History','/quiz/history'],['Geography','/quiz/geography'],['Sports','/quiz/sports']].map(([label,href]) => (
              <li><a href={href} style="transition:color 0.15s;" onmouseover="this.style.color='#c084fc'" onmouseout="this.style.color='#9ca3af'">{label}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <h3 style="color:white;font-size:14px;font-weight:700;margin-bottom:14px;text-transform:uppercase;letter-spacing:0.5px;">Site</h3>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:10px;font-size:14px;">
            {[['Home','/'],['Categories','/categories'],['Blog','/blog'],['About','/about'],['Contact','/contact']].map(([label,href]) => (
              <li><a href={href} style="transition:color 0.15s;" onmouseover="this.style.color='#c084fc'" onmouseout="this.style.color='#9ca3af'">{label}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <h3 style="color:white;font-size:14px;font-weight:700;margin-bottom:14px;text-transform:uppercase;letter-spacing:0.5px;">Legal</h3>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:10px;font-size:14px;">
            {[['Privacy Policy','/privacy-policy'],['Terms of Service','/terms']].map(([label,href]) => (
              <li><a href={href} style="transition:color 0.15s;" onmouseover="this.style.color='#c084fc'" onmouseout="this.style.color='#9ca3af'">{label}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Footer Ad -->
    <div style="border:1px dashed #374151;border-radius:8px;padding:16px;text-align:center;color:#4b5563;font-size:12px;margin-bottom:28px;">
      [Advertisement Space — Footer Banner]
    </div>

    <div style="border-top:1px solid #1f2937;padding-top:24px;display:flex;flex-wrap:wrap;gap:12px;justify-content:space-between;align-items:center;font-size:13px;">
      <p>&copy; {year} QuizZone. All rights reserved.</p>
      <p>Made for curious minds everywhere 🧠</p>
    </div>
  </div>
</footer>
