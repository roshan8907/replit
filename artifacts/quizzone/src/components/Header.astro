---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/categories', label: 'Categories' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
];
const currentPath = Astro.url.pathname;
---

<header style="background: #1e0a4e;">
  <div style="max-width:1200px;margin:0 auto;padding:0 16px;">
    <div style="display:flex;align-items:center;justify-content:space-between;height:62px;gap:16px;">

      <!-- Logo -->
      <a href="/" style="display:flex;align-items:center;gap:10px;flex-shrink:0;">
        <div style="width:38px;height:38px;background:linear-gradient(135deg,#a855f7,#6c35d3);border-radius:10px;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 12px rgba(108,53,211,0.4);">
          <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <span style="font-size:22px;font-weight:800;color:white;letter-spacing:-0.5px;">Quiz<span style="color:#c084fc;">Zone</span></span>
      </a>

      <!-- Desktop Nav -->
      <nav style="display:none;align-items:center;gap:4px;" class="desktop-nav">
        {navLinks.map((link) => (
          <a
            href={link.href}
            style={`padding:8px 16px;border-radius:8px;font-size:14px;font-weight:600;transition:all 0.15s;${currentPath === link.href ? 'background:rgba(255,255,255,0.15);color:white;' : 'color:rgba(255,255,255,0.7);'}`}
            onmouseover={`this.style.background='rgba(255,255,255,0.12)';this.style.color='white';`}
            onmouseout={`this.style.background='${currentPath === link.href ? 'rgba(255,255,255,0.15)' : 'transparent'}';this.style.color='${currentPath === link.href ? 'white' : 'rgba(255,255,255,0.7)'}';`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right: Search + Play Button -->
      <div style="display:flex;align-items:center;gap:10px;">
        <!-- Search Bar -->
        <div style="position:relative;display:none;" class="search-box">
          <input
            type="text"
            placeholder="Search quizzes..."
            style="padding:8px 12px 8px 36px;background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.2);border-radius:8px;color:white;font-size:13px;width:180px;outline:none;font-family:inherit;"
            onfocus="this.style.background='rgba(255,255,255,0.18)';this.style.borderColor='rgba(255,255,255,0.4)';"
            onblur="this.style.background='rgba(255,255,255,0.12)';this.style.borderColor='rgba(255,255,255,0.2)';"
          />
          <svg style="position:absolute;left:10px;top:50%;transform:translateY(-50%);opacity:0.5;" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </div>

        <a
          href="/categories"
          style="display:inline-flex;align-items:center;gap:6px;padding:9px 18px;background:linear-gradient(135deg,#a855f7,#7c3aed);color:white;font-size:14px;font-weight:700;border-radius:8px;white-space:nowrap;box-shadow:0 4px 12px rgba(124,58,237,0.4);transition:all 0.15s;border:none;"
          onmouseover="this.style.transform='translateY(-1px)';this.style.boxShadow='0 6px 16px rgba(124,58,237,0.5)';"
          onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 4px 12px rgba(124,58,237,0.4)';"
        >
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 010 1.972l-11.54 6.347a1.125 1.125 0 01-1.667-.986V5.653z" />
          </svg>
          Play Quiz
        </a>

        <!-- Mobile burger -->
        <button id="burger-btn" style="display:none;background:rgba(255,255,255,0.1);border:none;padding:8px;border-radius:8px;cursor:pointer;" class="burger-btn" aria-label="Menu">
          <svg id="burger-icon" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="close-icon" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2" style="display:none;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" style="display:none;border-top:1px solid rgba(255,255,255,0.1);background:#1e0a4e;">
    <div style="max-width:1200px;margin:0 auto;padding:12px 16px;display:flex;flex-direction:column;gap:4px;">
      {navLinks.map((link) => (
        <a
          href={link.href}
          style={`padding:12px 16px;border-radius:8px;font-size:15px;font-weight:600;${currentPath === link.href ? 'background:rgba(255,255,255,0.15);color:white;' : 'color:rgba(255,255,255,0.8);'}`}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<style>
  @media (min-width: 768px) {
    .desktop-nav { display: flex !important; }
    .search-box { display: block !important; }
  }
  @media (max-width: 767px) {
    .burger-btn { display: block !important; }
  }
</style>

<script>
  const burgerBtn = document.getElementById('burger-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const burgerIcon = document.getElementById('burger-icon');
  const closeIcon = document.getElementById('close-icon');
  let open = false;
  burgerBtn?.addEventListener('click', () => {
    open = !open;
    mobileMenu!.style.display = open ? 'block' : 'none';
    burgerIcon!.style.display = open ? 'none' : 'block';
    closeIcon!.style.display = open ? 'block' : 'none';
  });
</script>
